                      "box-shadow": "none"
                    }
                  }
                }
              },
              ".mbr-section-btn": {
                "margin-top": "70px",
                "text-align": "left"
              },
              ".btn-container": {
                "display": "none"
              }
            },
            "@media (max-width: 991px)": {
              ".navbar-brand": {
                "max-width": "60% !important",
                "width": "100% !important",
                "padding-right": "0 !important"
              },
              ".navbar-collapse": {
                "max-width": "100%",
