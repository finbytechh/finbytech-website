                  }
                },
                ".btn-black": {
                  "&:hover": {
                    "border": "1px solid #ede7e2 !important"
                  }
                },
                ".btn-white": {
                  "&:hover": {
                    "border": "1px solid #ede7e2 !important"
                  }
                }
              }
            },
            ".btn-container": {
              "width": "(100% / 3)",
              "margin": "-0.6rem",
              "padding-left": "0.6rem"
            },
            "& when (@collapsed)": {
              ".navbar-collapse": {
                "max-width": "100%",
                "width": "100%",
                "margin-left": "0",
                "padding-top": "6vw"
              },
              ".navbar-nav": {
                "border": "none",
                "background": "transparent",
                "max-width": "100%",
                ".nav-item": {
                  "display": "list-item",
                  "margin": "0 !important",
                  ".nav-link": {
                    "padding": "0 !important",
                    "margin": "0 0 20px !important",
                    "border-radius": "0",
                    "font-size": "76px",
                    "justify-content": "flex-start",
                    "&:hover": {
