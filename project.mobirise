          "_params": {}
        },
        {
          "_name": "article06",
          "_sourceTheme": "essencem5",
          "_styles": {
            "& when not (@fullScreen)": {
              "padding-top": "(@paddingTop * 1rem)",
              "padding-bottom": "(@paddingBottom * 1rem)"
            },
            "overflow": "hidden",
            "&::before": {
              "content": "''",
              "position": "absolute",
              "bottom": "0",
              "width": "200vh",
              "height": "25%",
              "background-image": "linear-gradient(transparent, @shadow 50%)",
              "z-index": "1"
            },
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            "& when (@fullWidth)": {
              ".container-fluid": {
                "padding": "0 80px",
                "@media (max-width: 1200px)": {
                  "padding": "0 40px"
                },
                "@media (max-width: 992px)": {
                  "padding": "0 22px"
                }
              }
            },
            ".container": {
              "@media (max-width: 992px)": {
                "padding": "0 22px"
              }
            },
            ".row": {
              "justify-content": "center"
            },
            ".content-wrapper": {
              "position": "relative",
              "z-index": "1",
              "padding": "100px 0",
              "@media (max-width: 992px)": {
                "padding": "0"
              },
              ".mbr-section-title": {
                "margin-bottom": "0"
              },
              ".mbr-desc": {
                "margin-bottom": "10px"
              }
            },
            ".mbr-section-title": {
              "color": "#ffffff"
            },
            ".mbr-desc": {
              "color": "#ffffff",
              "text-align": "center"
            },
            ".mbr-section-title, .mbr-section-btn": {
              "text-align": "center"
            }
          },
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"article06 essencem5\" group=\"Article\" mbr-class=\"{\n    'mbr-fullscreen': fullScreen,\n    'mbr-parallax-background': bg.parallax}\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Screen\" name=\"fullScreen\">\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\">\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"12\" step=\"1\" value=\"0\" condition=\"fullScreen == false\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"12\" step=\"1\" value=\"0\" condition=\"fullScreen == false\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Description\" name=\"showDesc\">\n        <input type=\"checkbox\" title=\"Buttons\" name=\"showButtons\">\n        <input type=\"color\" title=\"Shadow Color\" name=\"shadow\" value=\"#000000\">\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"@PROJECT_PATH@/assets/images/stockmarket-scaled-1-2000x1125.webp\" parallax selected>\n            <input type=\"color\" title=\"Color\" value=\"#000000\">\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"@PROJECT_PATH@/assets/images/background1-6.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#000000\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.6\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row\">\n            <div class=\"col-12 col-lg-10\">\n                <div class=\"content-wrapper\">\n                    <h2 class=\"mbr-section-title mbr-fonts-style\" data-app-selector=\".mbr-section-title, .mbr-section-btn\" mbr-theme-style=\"display-2\" mbr-if=\"showTitle\"><b>Home / API Products</b></h2>\n                    <p class=\"mbr-desc mbr-fonts-style\" data-app-selector=\".mbr-desc\" mbr-theme-style=\"display-7\" mbr-if=\"showDesc\">\n                        Write to us and subscribe on our social networks\n                    </p>\n                    <div mbr-buttons mbr-theme-style=\"display-4\" class=\"mbr-section-btn\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\">\n                        <a class=\"btn btn-secondary\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">\n                            Сontact now\n                        </a>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_anchor": "article06-5g",
          "_isUserblock": true,
          "_cid": "uwJBNe3dUp",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "_name": "afeatures1",
          "_sourceTheme": "structurem5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"features1 structurem5\" group=\"Features\" data-bg-video=\"{{bg.type == 'video' && bg.value.url}}\" mbr-class=\"{'mbr-parallax-background': bg.parallax}\" plugins=\"mobirise-icons2\">\n\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\" checked>\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"8\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"0\">\n        <input type=\"checkbox\" title=\"Reverse\" name=\"reverseContent\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Border\" name=\"showBorder\" checked>\n        <input type=\"color\" title=\"Border Color\" name=\"borderColor\" value=\"#fcdb42\" condition=\"showBorder\">\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\" checked>\n        <input type=\"checkbox\" title=\"List\" name=\"showList\" checked>\n        <input type=\"range\" inline title=\"List Count\" name=\"listCount\" min=\"1\" max=\"6\" step=\"1\" value=\"4\" condition=\"showList\">\n        <input type=\"checkbox\" title=\"Icons\" name=\"showIcon\" checked condition=\"showList\">\n        <input type=\"color\" title=\"Icon Color\" name=\"iconColor\" value=\"#090f10\" selected condition=\"showList && showIcon\">\n        <input type=\"color\" title=\"Icon Bg Color\" name=\"iconBgColor\" value=\"#fcdb42\" selected condition=\"showList && showIcon\">\n        <input type=\"checkbox\" title=\"Buttons\" name=\"showButtons\">\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"@ADDONS_PATH@/structurem5/components/_images/background3.jpg\" parallax>\n            <input type=\"color\" title=\"Color\" value=\"#090f10\" selected>\n            <input type=\"video\" title=\"Video\" value=\"https://vimeo.com/428046504\">\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"@ADDONS_PATH@/structurem5/components/_images/background3.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#090f10\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.5\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type!== 'color'\" mbr-style=\"{'opacity': overlayOpacity, 'background-color': overlayColor}\">\n    </div>\n    <div class=\"section-border-item section-border-item_top\" mbr-if=\"showBorder\"></div>\n    <div class=\"section-border-item section-border-item_center\" mbr-if=\"showBorder\"></div>\n    <div class=\"section-border-item section-border-item_bottom\" mbr-if=\"showBorder\"></div>\n    <div mbr-class=\"{'container-fluid':fullWidth, container:fullWidth==false}\">\n        <div class=\"main-container\">\n            <div class=\"card-wrap\">\n                <div class=\"card-box\" mbr-if=\"showTitle || showText || showList || showButtons\">\n                    <h4 class=\"card-title mbr-fonts-style mb-0\" mbr-theme-style=\"display-5\" mbr-if=\"showTitle\" data-app-selector=\".card-title\"><div><b>API BRIDGE FUNCTIONS.&nbsp;</b></div></h4>\n                    <p class=\"mbr-text mbr-fonts-style mb-0\" mbr-theme-style=\"display-4\" mbr-if=\"showText\" data-app-selector=\".mbr-text, .mbr-section-btn\">Algo Trading is a form of automated trading in which market data is analyzed by PC programs based on pre-defined parameters.\n<br>\n<br>It reduced human or manual innovation by placing transactions on the terminal and submitting them to exchange directly. By utilizing MetaTrade4 and MetaTrade5, it will assist us in making judgments and acting automatically, cutting down on rection time, and preventing human emotions from interfering with trading.\n<br>\n<br>We will provide you access to the greatest platform for auto trading using your own intraday and positional based technique. By controlling your emotions and avoiding manual involvement, we will help you save time and money. We use our programming to translate your logics and tactics.\n<br>\n<br>When the predetermined criteria are satisfied, a computer program that uses software will automatically keep an eye on the stock price(a well as the moving average indicators) and place buy and sell orders. The trader is no longer required to manually enter orders or monitor real-time cost and charts. This is automatically accomplished by the algorithmic trading system, which correctly and successfully recognizes the trade opportunity.\n<br>\n<br>Because of the many advantages listed below, algorithmic trading is advantageous for all types of investors, whether they are long-term or short-term.<br><br><b>Some Benefits for you:&nbsp;</b><br></p>\n                    <div class=\"counter-container\" mbr-if=\"showList\">\n                        <div class=\"list\">\n                            <div class=\"list-item\">\n                                <div class=\"iconfont-wrapper\" mbr-if=\"showIcon\">\n                                    <span mbr-icon class=\"mbr-iconfont mobi-mbri-success mobi-mbri\"></span>\n                                </div>\n                                <p class=\"list-text mbr-fonts-style mb-0\" mbr-theme-style=\"display-4\" data-app-selector=\".list-text\">Reasonable price - Trades are executed at the best possible price.&nbsp;<br></p>\n                            </div>\n                            <div class=\"list-item\" mbr-if=\"listCount > 1\">\n                                <div class=\"iconfont-wrapper\" mbr-if=\"showIcon\">\n                                    <span mbr-icon class=\"mbr-iconfont mobi-mbri-success mobi-mbri\"></span>\n                                </div>\n                                <p class=\"list-text mbr-fonts-style mb-0\" mbr-theme-style=\"display-4\" data-app-selector=\".list-text\">Errorless - Reduced risk of manual errors when placing trades.&nbsp;<br></p>\n                            </div>\n                            <div class=\"list-item\" mbr-if=\"listCount > 2\">\n                                <div class=\"iconfont-wrapper\" mbr-if=\"showIcon\">\n                                    <span mbr-icon class=\"mbr-iconfont mobi-mbri-success mobi-mbri\"></span>\n                                </div>\n                                <p class=\"list-text mbr-fonts-style mb-0\" mbr-theme-style=\"display-4\" data-app-selector=\".list-text\">Efficiency -  Trades are timed correctly and instantly to avoid significant price changes.&nbsp;<br></p>\n                            </div>\n                            <div class=\"list-item\" mbr-if=\"listCount > 3\">\n                                <div class=\"iconfont-wrapper\" mbr-if=\"showIcon\">\n                                    <span mbr-icon class=\"mbr-iconfont mobi-mbri-success mobi-mbri\"></span>\n                                </div>\n                                <p class=\"list-text mbr-fonts-style mb-0\" mbr-theme-style=\"display-4\" data-app-selector=\".list-text\">Less mistakes - Reduced the possibility of mistakes by human traders based on emotional and psychological factors.&nbsp;<br></p>\n                            </div>\n                            <div class=\"list-item\" mbr-if=\"listCount > 4\">\n                                <div class=\"iconfont-wrapper\" mbr-if=\"showIcon\">\n                                    <span mbr-icon class=\"mbr-iconfont mobi-mbri-success mobi-mbri\"></span>\n                                </div>\n                                <p class=\"list-text mbr-fonts-style mb-0\" mbr-theme-style=\"display-7\" data-app-selector=\".list-text\">\n                                    Elementum nisi quis eleifend quam\n                                </p>\n                            </div>\n                            <div class=\"list-item\" mbr-if=\"listCount > 5\">\n                                <div class=\"iconfont-wrapper\" mbr-if=\"showIcon\">\n                                    <span mbr-icon class=\"mbr-iconfont mobi-mbri-success mobi-mbri\"></span>\n                                </div>\n                                <p class=\"list-text mbr-fonts-style mb-0\" mbr-theme-style=\"display-7\" data-app-selector=\".list-text\">\n                                    Ipsum dolor sit amet consectetur\n                                </p>\n                            </div>\n                        </div>\n                    </div>\n                    <div mbr-buttons mbr-theme-style=\"display-7\" class=\"mbr-section-btn mb-0\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\"><a class=\"btn btn-primary\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">\n                            <span class=\"mobi-mbri mobi-mbri-right mbr-iconfont mbr-iconfont-btn\"></span>\n                            Learn More About Our Services\n                        </a></div>\n                </div>\n            </div>\n            <div class=\"image-wrapper\">\n                <div class=\"img-box\">\n                    <img src=\"@PROJECT_PATH@/assets/images/will-machine-learning-ai-make-human-translators-an-endangered-species-735x473.webp\" alt=\"Mobirise Website Builder\">\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_styles": {
            "padding-top": "(@paddingTop * 1rem)",
            "padding-bottom": "(@paddingBottom * 1rem)",
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            "position": "relative",
            "margin-top": "-1px",
            "overflow": "hidden",
            ".section-border-item": {
              "background-color": "@borderColor",
              "&_center": {
                "@media (max-width: 991px)": {
                  "display": "none"
                }
              }
            },
            ".main-container": {
              "display": "flex",
              "align-items": "center",
              "padding": "3rem 0",
              "& when (@reverseContent)": {
                "flex-direction": "row-reverse"
              },
              "@media (max-width: 991px)": {
                "flex-wrap": "wrap"
              }
            },
            ".card-wrap": {
              "width": "50%",
              "@media (max-width: 991px)": {
                "width": "100%"
              }
            },
            ".card-box": {
              "width": "100%",
              "padding-right": "10vw",
              "& when (@reverseContent)": {
                "padding-right": "0",
                "padding-left": "10vw"
              },
              "@media (max-width: 991px)": {
                "max-width": "32rem",
                "margin-right": "auto",
                "padding-right": "0",
                "padding-left": "0",
                "padding-bottom": "3rem"
              },
              "@media (max-width: 767px)": {
                "max-width": "100%"
              }
            },
            ".card-title": {
              "color": "#FFF"
            },
            ".mbr-text": {
              "color": "#FFF",
              "margin-top": "1.5rem",
              "@media (max-width: 767px)": {
                "margin-top": "1.25rem"
              }
            },
            ".counter-container": {
              "margin-top": "2rem",
              "@media (max-width: 767px)": {
                "margin-top": "1.5rem"
              }
            },
            ".list": {
              "display": "flex",
              "flex-wrap": "wrap",
              "gap": "1rem",
              "padding": "8px 0"
            },
            ".list-item": {
              "display": "flex",
              "align-items": "center",
              "width": "100%"
            },
            ".iconfont-wrapper": {
              "display": "flex",
              "align-items": "center",
              "justify-content": "center",
              "padding": "5px",
              "margin-right": "1rem",
              "border-radius": "50%",
              "background-color": "@iconBgColor",
              ".mbr-iconfont": {
                "display": "block",
                "font-size": "12px",
                "color": "@iconColor"
              }
            },
            ".list-text": {
              "color": "#FFF",
              "flex-grow": "1"
            },
            ".mbr-section-btn": {
              "margin-top": "1.5rem",
              "@media (max-width: 767px)": {
                "margin-top": "1rem"
              }
            },
            ".image-wrapper": {
              "display": "flex",
              "align-items": "center",
              "justify-content": "center",
              "width": "50%",
              "padding-left": "2.5rem",
              "& when (@reverseContent)": {
                "padding-right": "2.5vw",
                "padding-left": "0"
              },
              "@media (max-width: 991px)": {
                "position": "relative",
                "width": "100%",
                "padding-right": "0",
                "padding-left": "0",
                "padding-top": "3rem",
                "& when (@showBorder)": {
                  "&:before": {
                    "content": "\"\"",
                    "position": "absolute",
                    "top": "0",
                    "left": "50%",
                    "transform": "translateX(-50%)",
                    "width": "100vw",
                    "height": "1px",
                    "background-color": "@borderColor"
                  }
                }
              }
            },
            ".img-box": {
              "display": "flex",
              "align-items": "center",
              "justify-content": "center",
              "width": "100%",
              "max-width": "38rem",
              "img": {
                "width": "100%",
                "object-fit": "cover"
              }
            }
          },
          "_cid": "uwF9rhPsoD",
