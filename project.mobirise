                  }
                },
                ".btn-black": {
                  "&:hover": {
                    "border": "1px solid #ede7e2 !important"
                  }
                },
                ".btn-white": {
                  "&:hover": {
                    "border": "1px solid #ede7e2 !important"
                  }
                }
              }
            },
            ".btn-container": {
              "width": "(100% / 3)",
              "margin": "-0.6rem",
              "padding-left": "0.6rem"
            },
            "& when (@collapsed)": {
              ".navbar-collapse": {
                "max-width": "100%",
