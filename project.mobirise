                  "height": "auto"
                }
              },
              ".nav-item .nav-link:hover::before": {
                "width": "175%",
                "max-width": "calc(100% ~\"+\" 2rem)",
                "left": "-1rem"
              }
            },
            ".navbar-collapse": {
              "max-width": "75%",
              "width": "100%",
              "margin-left": "auto"
            },
            ".navbar-nav": {
              "justify-content": "center",
              "margin-right": "auto",
              "margin-left": "auto",
              "max-width": "70%",
              "border-radius": "1.7vw",
              "overflow": "hidden",
              "border": "1px solid @menuBorderColor",
              "& when not (@transparent)": {
