            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            ".left-side": {
              "text-align": "left",
              "padding": "5rem"
            },
            ".row": {
              "align-items": "center"
            },
            "@media (max-width: 600px)": {
              ".mbr-section-btn": {
                "margin-bottom": "25px"
              },
              ".mbr-section-title": {
                "margin-top": "25px"
              },
              ".left-side": {
                "padding": "1rem"
              }
            },
            ".mbr-section-subtitle": {
              "color": "#000000",
              "text-transform": "uppercase"
