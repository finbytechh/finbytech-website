                }
              },
              "padding": "1.6666666667vw 0 !important",
              "border": "none !important"
            },
            ".navbar-brand": {
              "min-height": "70px !important",
              "flex-shrink": "0",
              "align-items": "center",
              "margin-right": "auto",
              "padding": "0",
              "transition": "all 0.3s",
              "word-break": "break-word",
              "z-index": "1",
              "font-weight": "500 !important",
              ".navbar-caption": {
                "line-height": "inherit !important",
