                    "border-radius": "0",
                    "font-size": "7.6vw",
                    "justify-content": "flex-start",
                    "&:hover": {
                      "background-color": "transparent",
                      "color": "@menuBorderColor !important",
                      "box-shadow": "none"
                    }
                  }
                }
              },
              ".mbr-section-btn": {
                "margin-top": "6.9vw",
