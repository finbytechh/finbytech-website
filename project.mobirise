              "flex-basis": "0",
              "-ms-flex-positive": "1",
              "flex-grow": "1",
              "max-width": "100%"
            },
            ".col-md-auto": {
              "position": "relative",
              "padding-right": "15px",
              "padding-left": "15px",
              "-ms-flex": "0 0 auto",
              "flex": "0 0 auto",
              "width": "auto",
              "max-width": "100%"
            },
            ".mbr-section-btn": {
              "margin": "0",
              ".btn": {
                "margin": "0"
              }
            }
          },
          "_name": "mbr-popup",
          "_sourceTheme": "mobirise5",
          "_customHTML": "<section class=\"popup-builder\" group=\"Popup\" plugins=\"formstyler, datepicker\">\n\n    <mbr-parameters>\n        <!-- Block parameters controls (Blue \"Gear\" panel) -->\n        <header>Triggers / Show Popup</header>\n        <label>On Click</label>\n        <label>Use [popup-id] with any link or button (Link -&gt; Popup tab)</label>\n        <input type=\"checkbox\" title=\"On Timer\" name=\"onTimer\">\n        <input type=\"range\" title=\"Delay (s)\" name=\"onTimerDelay\" min=\"0\" max=\"30\" step=\"1\" value=\"5\" condition=\"onTimer == true\">\n\n        <input type=\"checkbox\" title=\"On Page Exit\" name=\"onPageExit\">\n\n        <input type=\"checkbox\" title=\"On Scroll to End\" name=\"onScroll\">\n\n        <select title=\"Add to Pages:\" name=\"popupOnPages\" multiple condition=\"onTimer == true || onPageExit == true || onScroll == true\"></select>\n\n        <header>Content</header>\n        <input type=\"checkbox\" title=\"Show Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Show Text\" name=\"showText\">\n\n        <select title=\"Content Type\" name=\"popupContentType\">\n            <option value=\"1\">None</option>\n            <option value=\"2\">Image</option>\n            <option value=\"3\">Video</option>\n            <option value=\"4\" selected>Form</option>\n        </select>\n\n        <select title=\"Size\" name=\"popupSize\">\n            <option value=\"1\">Small</option>\n            <option value=\"2\" selected>Default</option>\n            <option value=\"3\">Large</option>\n            <option value=\"4\">Extra large</option>\n            <option value=\"5\">Full Screen</option>\n        </select>\n        <input type=\"checkbox\" title=\"Show Buttons\" name=\"showButtons\">\n\n        <input type=\"color\" title=\"Background Color\" name=\"cardBg\" value=\"#2380ae\">\n        <input type=\"color\" title=\"Close Button\" name=\"closeButton\" value=\"#e43f3f\">\n\n        <header>Overlay</header>\n        <input type=\"color\" title=\"Color\" name=\"popupOverlayColor\" value=\"#000000\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.7\">\n        <!-- End block parameters -->\n    <input type=\"hidden\" name=\"usedRecaptcha\" value=\"false\"></mbr-parameters>\n\n    <div class=\"mbr-overlay\" mbr-style=\"{'opacity': overlayOpacity, 'background-color': popupOverlayColor, 'top': 0, 'right': 0, 'bottom': 0, 'left': 0, 'position': absolute, 'z-index': 0, 'pointer-events': none}\">\n    </div>\n\n    <div class=\"modal mbr-popup\" tabindex=\"-1\" role=\"dialog\" data-overlay-color=\"{{popupOverlayColor}}\" data-overlay-opacity=\"{{overlayOpacity}}\" data-on-timer-delay=\"{{onTimer ? onTimerDelay : ''}}\" data-on-exit=\"{{onPageExit}}\" data-on-scroll=\"{{onScroll}}\">\n        <div class=\"modal-dialog\" role=\"document\" mbr-class=\"{\n            'modal-sm': popupSize == 1,\n            '': popupSize == 2,\n            'modal-lg': popupSize == 3,\n            'modal-xl': popupSize == 4\n            }\">\n            <div class=\"modal-content\">\n                <div class=\"container position-static margin-center-pos\">\n                    <div class=\"modal-header\" mbr-class=\"{'pb-0': showTitle && showText}\">\n                        <h5 class=\"modal-title mbr-fonts-style\" mbr-theme-style=\"display-5\" data-app-selector=\".modal-title\" mbr-if=\"showTitle\"><b>Fill your requirements&nbsp;</b></h5>\n                        <button type=\"button\" class=\"close d-flex\" data-dismiss=\"modal\" data-bs-dismiss=\"modal\" aria-label=\"Close\">\n                            <svg version=\"1.1\" xmlns=\"http://www.w3.org/2000/svg\" width=\"23\" height=\"23\" viewBox=\"0 0 23 23\" fill=\"currentColor\">\n                                <path d=\"M13.4 12l10.3 10.3-1.4 1.4L12 13.4 1.7 23.7.3 22.3 10.6 12 .3 1.7 1.7.3 12 10.6 22.3.3l1.4 1.4L13.4 12z\">\n                                </path>\n                            </svg>\n                        </button>\n                    </div>\n\n                    <div class=\"modal-body\">\n                        <p class=\"mbr-text mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".mbr-text\" mbr-if=\"showText\">\n                            Please fill</p>\n\n                        <div mbr-if=\"popupContentType !== 1\">\n                            <div class=\"card-img mbr-figure\" mbr-if=\"popupContentType == 2\">\n                                <img src=\"../_images/popup.jpg\" alt=\"Mobirise\">\n                            </div>\n                            <div mbr-video class=\"video-block mbr-figure\" mbr-if=\"popupContentType == 3\">\n                                <iframe src=\"http://www.youtube.com/watch?v=uNCr7NdOJgw\"></iframe>\n                            </div>\n\n                            <div mbr-form mbr-if=\"popupContentType == 4\" class=\"form-wrapper\">\n<!--Formbuilder Form-->\n<form action name=\"Mobirise Form\" method=\"POST\" class=\"mbr-form form-with-styler\">\n<div class>\n<div hidden=\"hidden\" data-form-alert class=\"alert alert-success col-12\"> Thanks for filling out the form!</div>\n<div hidden=\"hidden\" data-form-alert-danger class=\"alert alert-danger col-12\"> </div>\n</div>\n<div class=\"dragArea row\">\n<div class=\"col-lg-12 col-md-12 col-sm-12 form-group\" data-for=\"name\">\n<input type=\"text\" name=\"name\" placeholder=\"Name\" data-form-field=\"Name\" mbr-theme-style=\"display-7\" required=\"required\" class=\"form-control\" value>\n</div>\n<div class=\"col-lg-12 col-md-12 col-sm-12 form-group \" data-for=\"email\">\n<input type=\"email\" name=\"email\" placeholder=\"Email\" data-form-field=\"Email\" mbr-theme-style=\"display-7\" required=\"required\" class=\"form-control\" value>\n</div>\n<div data-for=\"lastName\" class=\"col-lg-12 col-md-12 col-sm-12 form-group\">\n<input type=\"text\" name=\"lastName\" placeholder=\"Contact Number\" data-form-field=\"Last Name\" mbr-theme-style=\"display-7\" class=\"form-control\" required=\"required\" value>\n</div>\n<div data-for=\"text\" class=\"col-lg-12 col-md-12 col-sm-12 form-group\">\n<input type=\"text\" name=\"text\" placeholder=\"City\" data-form-field=\"text\" mbr-theme-style=\"display-7\" class=\"form-control\" required=\"required\" value>\n</div>\n<div data-for=\"textarea\" class=\"col-lg-12 col-md-12 col-sm-12 form-group\">\n<textarea name=\"textarea\" placeholder=\"Please specify your requirement in few details\" data-form-field=\"textarea\" mbr-theme-style=\"display-7\" class=\"form-control\"></textarea>\n</div>\n<div class=\"col-md-auto input-group-btn\" mbr-buttons=\"true\" mbr-theme-style=\"display-4\" data-toolbar=\"-mbrBtnMove,-mbrLink,-mbrBtnRemove,-mbrBtnAdd\"><a type=\"submit\" class=\"w-100 w-100 btn btn-success\" data-app-placeholder=\"Type Text\"><span class=\"mobi-mbri mobi-mbri-hearth mbr-iconfont mbr-iconfont-btn\"></span>Submit</a></div>\n</div>\n</form><!--Formbuilder Form-->\n</div>\n                        </div>\n                    </div>\n\n                    <div class=\"modal-footer\" mbr-class=\"{'pt-0': popupContentType == 1 || popupContentType == 4}\" mbr-if=\"showButtons\">\n                        <div class=\"mbr-section-btn\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\" mbr-buttons mbr-theme-style=\"display-4\">\n                            <a class=\"btn btn-md btn-primary\" href=\"https://mobiri.se\">\n                                LEARN MORE\n                            </a>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n\n</section>",
          "_cid": "uWLMax0ywD",
          "_anchor": "mbr-popup-bn",
          "_popupId": "mbr-popup-bn",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "_name": "afeatures6",
          "_sourceTheme": "cyberm5",
          "_styles": {
            "padding-top": "(@paddingTop * 1rem)",
            "padding-bottom": "(@paddingBottom * 1rem)",
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            "overflow": "hidden",
            "position": "relative",
            ".container, .container-fluid": {
              "position": "static"
            },
            ".row": {},
            ".text-wrapper": {
              "@media (min-width: 1400px)": {
                "& when not (@reverseContent)": {
                  "padding-right": "48px"
                },
                "& when (@reverseContent)": {
                  "padding-left": "48px"
                }
              }
            },
            ".label-text": {
              "width": "100%",
              "color": "#913BFF",
              "margin-bottom": "20px",
              "span": {
                "padding": "8px 18px",
                "background-color": "@labelBg",
                "border-radius": "15px",
                "color": "inherit"
              }
            },
            ".mbr-section-title": {
              "color": "#22a5e5",
              "margin-bottom": "0",
              "text-align": "left"
            },
            ".mbr-text": {
              "color": "#00284E",
              "opacity": "0.8",
              "margin-bottom": "15px",
              "margin-top": "20px"
            },
            ".mbr-section-btn": {
              "margin-top": "6px"
            },
            ".image-wrapper": {
              "height": "650px",
              "position": "relative",
              "z-index": "2",
              "img": {
                "height": "100%",
                "object-fit": "contain",
                "max-width": "100%",
                "& when not (@reverseContent)": {
                  "margin-left": "auto!important"
                },
                "& when (@reverseContent)": {
                  "margin-right": "auto!important"
                }
              },
              "@media (min-width: 768px)": {
                "position": "absolute",
                "z-index": "2",
                "top": "0",
                "width": "32.7%",
                "padding-top": "(@paddingTop * 1rem)",
                "& when not (@reverseContent)": {
                  "right": "7%"
                },
                "& when (@reverseContent)": {
                  "left": "7%"
                },
                "padding-right": "0",
                "padding-left": "0"
              },
              "@media (min-width: 1200px) and (max-width: 1399px)": {
                "width": "40%",
                "& when not (@reverseContent)": {
                  "right": "1%"
                },
                "& when (@reverseContent)": {
                  "left": "1%"
                }
              },
              "@media (min-width: 992px) and (max-width: 1199px)": {
                "width": "40%",
                "top": "0",
                "& when not (@reverseContent)": {
                  "right": "1%"
                },
                "& when (@reverseContent)": {
                  "left": "1%"
                }
              },
              "@media (min-width: 768px) and (max-width: 991px)": {
                "width": "40%",
                "top": "8%",
                "& when not (@reverseContent)": {
                  "right": "1%"
                },
                "& when (@reverseContent)": {
                  "left": "1%"
                }
              },
              "@media (max-width: 767px)": {
                "max-width": "474px !important",
                "margin": "80px auto 0"
              }
            },
            ".bg-round": {
              "position": "absolute",
              "top": "-55%",
              "padding": "0",
              "padding-top": "(@paddingTop * 1rem)",
              "svg": {
                "max-width": "100%",
                "max-height": "100%",
                "width": "100%",
                "object-fit": "cover"
              },
              "@media (min-width: 768px)": {
                "width": "56%",
                "& when not (@reverseContent)": {
                  "right": "0",
                  "transform": "scale(-1, 1)"
                },
                "& when (@reverseContent)": {
                  "left": "0"
                }
              },
              "@media (min-width: 992px) and (max-width: 1399px)": {
                "width": "44%"
              },
              "@media (min-width: 768px) and (max-width: 991px)": {
                "width": "50%"
              },
              "@media (max-width: 767px)": {
                "display": "none"
              }
            },
            ".col-text": {
              "position": "relative",
              "z-index": "3",
              "@media (min-width: 768px)": {
                "& when not (@reverseContent)": {
                  "margin-right": "auto"
                },
                "& when (@reverseContent)": {
                  "margin-left": "auto"
                }
              }
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            }
          },
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"features6\" group=\"Features\" data-bg-video=\"{{bg.type == 'video' && bg.value.url}}\" mbr-class=\"{\n    'mbr-fullscreen': fullScreen,\n    'mbr-parallax-background': bg.parallax}\">\n\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\">\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"6\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"10\">\n        <input type=\"checkbox\" title=\"Reverse\" name=\"reverseContent\" checked>\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Label\" name=\"showLabel\">\n        <input type=\"color\" title=\"Label BG\" name=\"labelBg\" value=\"#f0e4ff\" condition=\"showLabel\">\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\">\n        <input type=\"checkbox\" title=\"Buttons\" name=\"showButtons\">\n        <input type=\"checkbox\" title=\"Image BG\" name=\"showImgBg\" checked>\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"@PROJECT_PATH@/assets/images/background1-2.jpg\">\n            <input type=\"color\" title=\"Color\" value=\"#ffffff\">\n            <input type=\"video\" title=\"Video\" value=\"https://youtu.be/0x5mf8BUJZY?si=DSq8zogwitmui5eA\" selected>\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"@PROJECT_PATH@/assets/images/background1-2.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#000000\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.9\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n\n\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row justify-content-center\">\n\n            <div class=\"col-12 col-lg-6 col-md-7 col-text\">\n                <div class=\"text-wrapper\">\n                    <p class=\"label-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showLabel\" data-app-selector=\".label-text\">\n                        <span>CONTACT US</span>\n                    </p>\n                    <h1 class=\"mbr-section-title mbr-fonts-style\" data-app-selector=\".mbr-section-title\" mbr-theme-style=\"display-5\" mbr-if=\"showTitle\"><b>Our Approach To Each Your Business Goals !</b></h1>\n                    <p class=\"mbr-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showText\" data-app-selector=\".mbr-text, .mbr-section-btn\">\n                        Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed eiusmod tempor\n                        incididunt ut labore et dolore magna aliqua. Ut quis nostrud ullamco laboris nisi.\n                    </p>\n                    <div mbr-buttons mbr-theme-style=\"display-7\" class=\"mbr-section-btn\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\"><a class=\"btn btn-primary\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">Send Message</a>\n                    </div>\n                </div>\n            </div>\n            <div class=\"col-12 image-wrapper\">\n                <img class=\"w-100\" src=\"@PROJECT_PATH@/assets/images/features4.svg\" alt=\"Mobirise\">\n            </div>\n            <div class=\"bg-round\" mbr-if=\"showImgBg\">\n                <svg xmlns=\"http://www.w3.org/2000/svg\" preserveAspectRatio=\"auto\" width=\"628\" height=\"876\" viewBox=\"0 0 628 876\" fill=\"none\">\n                    <rect x=\"231.129\" y=\"1039.63\" width=\"909.521\" height=\"792.67\" rx=\"396.335\" transform=\"rotate(-135 231.129 1039.63)\" fill=\"url(#paint0_linear_462_323)\"></rect>\n                    <defs>\n                        <linearGradient id=\"paint0_linear_462_323\" x1=\"280.745\" y1=\"1480.86\" x2=\"1089.32\" y2=\"1480.85\" gradientUnits=\"userSpaceOnUse\">\n                            <stop stop-color=\"#F6FDFF\"></stop>\n                            <stop offset=\"1\" stop-color=\"white\" stop-opacity=\"0\"></stop>\n                        </linearGradient>\n                    </defs>\n                </svg>\n            </div>\n        </div>\n    </div>\n</section>",
          "_anchor": "afeatures6-9s",
          "_isUserblock": true,
          "_cid": "uW6m8bwB4z",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "alias": false,
          "_styles": {
            "padding-top": "(@paddingTop * 1rem)",
            "padding-bottom": "(@paddingBottom * 1rem)",
            "& when (@bg-type = \"color\")": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = \"image\")": {
              "background-image": "url(@bg-value)",
              "& when (@overlay)": {
                ".mbr-overlay": {
                  "background": "@overlayColor",
                  "opacity": "@overlayOpacity"
                }
              }
            },
            ".item-img": {
              "position": "relative",
              "img": {
                "transition": "all 0.2s"
              }
            },
            ".item": {
              "&:hover": {
                "cursor": "pointer",
                "transform": "translateY(-6px)",
                ".link-icon-wrapper span": {
                  "transform": "rotate(-20deg) scale(1.3)"
                },
                "img": {
                  "transform": "scale(1.05)"
                }
              },
              "transition": "transform 0.3s",
              "margin-bottom": "2rem"
            },
            ".mbr-section-subtitle": {
              "border": "1px solid currentColor",
              "border-radius": "1rem",
              "width": "fit-content",
              "padding": "0.2rem 0.7rem",
              "display": "inline-block"
            },
            ".image-wrapper": {
              "overflow": "hidden",
              "border-radius": "2rem"
            },
            ".item-wrapper": {
              "position": "relative",
              "background": "@cardsBg",
              "border": "3px solid @cardsBg",
              "height": "100%",
              "display": "flex",
              "flex-flow": "column nowrap",
              ".item-footer": {
                "margin-top": "auto"
              }
            },
            ".item-link": {
              "position": "absolute",
              "bottom": "8px",
              "right": "90px",
              "color": "#ffffff"
            },
            ".link-icon-wrapper": {
              "position": "absolute",
              "right": "-1px",
              "padding": "2px",
              "bottom": "-1px",
              "background": "@cardsBg",
              "width": "68px",
              "height": "68px",
              "display": "flex",
              "justify-content": "flex-end",
              "align-items": "flex-end",
              "border-top-left-radius": "50%",
              "border-bottom-right-radius": "2rem",
              "z-index": "3",
              ".icon-wrap": {
                "background": "@iconBg",
                "width": "55px",
                "height": "55px",
                "transition": "all 0.3s",
                "display": "flex",
                "justify-content": "center",
                "align-items": "center",
                "border-radius": "50%",
                "span": {
                  "color": "@iconColor",
                  "font-size": "1.1rem",
                  "transition": "all 0.3s",
                  "display": "block",
                  "padding-top": "1px"
                }
              },
              ".svg1": {
                "position": "absolute",
                "top": "-29px",
                "right": "0px",
                "transform": "rotate(180deg)",
                "width": "30px",
                "path": {
                  "fill": "@cardsBg"
                }
              },
              ".svg2": {
                "position": "absolute",
                "transform": "rotate(180deg)",
                "width": "30px",
                "bottom": "0",
                "left": "-29px",
                "path": {
                  "fill": "@cardsBg"
                }
              }
            },
            ".item-content": {
              "position": "absolute",
              "top": "0",
              "left": "0",
              "margin-top": "1rem",
              "padding": "0 1.5rem 2rem",
              "@media (max-width: 767px)": {
                "padding": "0 1rem 1.4rem",
                "margin-top": "1rem"
              },
              "display": "flex",
              "flex-direction": "column",
              "height": "100%"
            },
            "img, .item-img": {
              "width": "100%",
              "& when (@autoSize)": {
                "height": "(@imageHeight * 100px)",
                "object-fit": "cover"
              }
            },
            ".item:focus, span:focus": {
              "outline": "none"
            },
            "@media (max-width: 767px)": {
              ".item": {
                "margin-bottom": "1rem"
              }
            },
            "& when not (@spacing)": {
              ".row": {
                "margin-left": "0",
                "margin-right": "0"
              },
              ".item": {
                "padding": "0",
                "margin": "0"
              }
            },
            ".mbr-section-title": {
              "color": "#000000",
              "text-align": "left"
            },
            ".item-title": {
              "text-align": "center",
              "color": "#ffffff"
            },
            ".item-subtitle": {
              "text-align": "left",
              "color": "#ffffff"
            },
            ".mbr-section-subtitle, .subtitle-wrap, .mbr-section-btn": {
              "text-align": "left",
              "color": "#22a5e5"
            },
            ".mbr-text, .item .mbr-section-btn": {
              "color": "#ffffff"
            }
          },
          "_name": "features1",
          "_sourceTheme": "ascentm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"ascentm5 features1\" group=\"Features\">\n  <mbr-parameters>\n    <header>Size</header>\n    <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\" checked>\n    <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"1\">\n    <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"1\">\n    <select title=\"Columns\" name=\"cardsWidth\">\n      <option value=\"12\">1</option>\n      <option value=\"6\">2</option>\n      <option value=\"4\" selected>3</option>\n      <option value=\"3\">4</option>\n    </select>\n    <header>Show/Hide</header>\n    <input type=\"checkbox\" name=\"showTitle\" title=\"Title\">\n    <input type=\"checkbox\" name=\"showSubtitle\" title=\"Subtitle\" checked>\n    <header>Cards</header>\n    <input type=\"checkbox\" name=\"autoSize\" title=\"Auto Size\" checked>\n    <input type=\"range\" name=\"imageHeight\" title=\"Height\" min=\"2\" max=\"5\" step=\"1\" value=\"2\" condition=\"autoSize && !(showButtons==false && showCardSubtitle==false && showCardTitle==false && showText==false)\">\n    <input type=\"checkbox\" title=\"Spacing\" name=\"spacing\">\n    <input type=\"checkbox\" name=\"showCardTitle\" title=\"Title\">\n    <input type=\"checkbox\" name=\"showCardSubtitle\" title=\"Subtitle\">\n    <input type=\"checkbox\" name=\"showText\" title=\"Text\">\n    <input type=\"checkbox\" name=\"showLink\" title=\"Link\">\n    <input type=\"color\" name=\"cardsBg\" title=\"Card BG\" value=\"#0c86c1\">\n    <input type=\"color\" name=\"iconColor\" title=\"Icon Color\" value=\"#ffffff\">\n    <input type=\"color\" name=\"iconBg\" title=\"Icon BG\" value=\"#000000\">\n\n    <header>Background</header>\n    <fieldset type=\"background\" name=\"bg\" required>\n      <input type=\"image\" title=\"Image\" value=\"@ADDONS_PATH@/ascentm5/components/_images/background1.jpg\">\n      <input type=\"color\" title=\"Color\" value=\"#000000\" selected>\n    </fieldset>\n    <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\n    <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#fafafa\" condition=\"overlay && bg.type == 'image'\">\n    <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.1\" condition=\"overlay && bg.type == 'image'\">\n  </mbr-parameters>\n  <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\"></div>\n  <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n    <div class=\"row justify-content-center\">\n      <div class=\"col-12 content-head\">\n        <div class=\"mbr-section-head mb-4\" mbr-if=\"showTitle || showSubtitle || showmainButton\">\n          <h4 class=\"mbr-section-title mbr-fonts-style align-center mb-0\" mbr-theme-style=\"display-2\" mbr-if=\"showTitle\" data-app-selector=\".mbr-section-title\">\n            <b>Title</b>\n          </h4>\n          <div class=\"subtitle-wrap w-100\">\n            <h5 class=\"mbr-section-subtitle mbr-fonts-style align-center mb-0 mt-3\" mbr-theme-style=\"display-7\" mbr-if=\"showSubtitle\" data-app-selector=\".mbr-section-subtitle, .subtitle-wrap, .mbr-section-btn\"><b>Our Services</b></h5>\n          </div>\n        </div>\n      </div>\n    </div>\n    <div class=\"row\">\n      <div class=\"item features-image col-12 col-md-6 col-lg-{{cardsWidth}} active\">\n        <div class=\"item-wrapper\">\n          <div class=\"item-img\">\n            <div class=\"image-wrapper\">\n              <img src=\"@PROJECT_PATH@/assets/images/invozone-mobile-app-development-735x490.jpg\" alt=\"Mobirise Website Builder\" data-slide-to=\"1\" data-bs-slide-to=\"1\">\n            </div>\n\n            <div class=\"link-icon-wrapper\">\n              <svg class=\"svg1\" viewBox=\"0 0 100 100\">\n                <path d=\"m100,0H0v100C0,44.77,44.77,0,100,0Z\"></path>\n              </svg>\n\n              <div class=\"icon-wrap\">\n                <a href=\"Service.html\"><span mbr-icon class=\"mbr-iconfont mbr-iconfont-btn mobi-mbri-right mobi-mbri\"></span></a>\n              </div>\n\n              <svg class=\"svg2\" viewBox=\"0 0 100 100\">\n                <path d=\"m100,0H0v100C0,44.77,44.77,0,100,0Z\"></path>\n              </svg>\n\n            </div>\n\n            <div class=\"item-content\" mbr-if=\"showCardTitle || showCardSubtitle || showText || showButtons\">\n              <h5 class=\"item-title mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".item-title\" mbr-if=\"showCardTitle\">\n                <b>API BRIDGE SOFTWARE</b></h5>\n              <h6 class=\"item-subtitle mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".item-subtitle\" mbr-if=\"showCardSubtitle\">\n                Subtitle</h6>\n              <p class=\"mbr-text mbr-fonts-style\" mbr-if=\"showText\" mbr-theme-style=\"display-7\" data-app-selector=\".mbr-text, .item .mbr-section-btn\">\n                Lorem ipsum dolor sit amet, consectetur adipiscing elit habitant turpis.\n              </p>\n            </div>\n            <h4 class=\"item-link mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".item-link\" mbr-if=\"showLink\">\n              <a href=\"#\" class=\"text-white\">Read more</a>\n            </h4>\n\n          </div>\n\n\n        </div>\n      </div><div class=\"item features-image col-12 col-md-6 col-lg-{{cardsWidth}}\">\n        <div class=\"item-wrapper\">\n          <div class=\"item-img\">\n            <div class=\"image-wrapper\">\n              <img src=\"@PROJECT_PATH@/assets/images/digital-marketing-1-736x940.jpg\" alt=\"Mobirise Website Builder\" data-slide-to=\"1\" data-bs-slide-to=\"1\">\n            </div>\n\n            <div class=\"link-icon-wrapper\">\n              <svg class=\"svg1\" viewBox=\"0 0 100 100\">\n                <path d=\"m100,0H0v100C0,44.77,44.77,0,100,0Z\"></path>\n              </svg>\n\n              <div class=\"icon-wrap\">\n                <a href=\"Digital Marketing.html\"><span mbr-icon class=\"mbr-iconfont mbr-iconfont-btn mobi-mbri-right mobi-mbri\"></span></a>\n              </div>\n\n              <svg class=\"svg2\" viewBox=\"0 0 100 100\">\n                <path d=\"m100,0H0v100C0,44.77,44.77,0,100,0Z\"></path>\n              </svg>\n\n            </div>\n\n            <div class=\"item-content\" mbr-if=\"showCardTitle || showCardSubtitle || showText || showButtons\">\n              <h5 class=\"item-title mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".item-title\" mbr-if=\"showCardTitle\">\n                <b>DIGITAL MARKETING</b></h5>\n              <h6 class=\"item-subtitle mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".item-subtitle\" mbr-if=\"showCardSubtitle\">\n                Subtitle</h6>\n              <p class=\"mbr-text mbr-fonts-style\" mbr-if=\"showText\" mbr-theme-style=\"display-7\" data-app-selector=\".mbr-text, .item .mbr-section-btn\">\n                Lorem ipsum dolor sit amet, consectetur adipiscing elit habitant turpis.\n              </p>\n            </div>\n            <h4 class=\"item-link mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".item-link\" mbr-if=\"showLink\">\n              <a href=\"#\" class=\"text-white\">Read more</a>\n            </h4>\n\n          </div>\n\n\n        </div>\n      </div><div class=\"item features-image col-12 col-md-6 col-lg-{{cardsWidth}}\">\n        <div class=\"item-wrapper\">\n          <div class=\"item-img\">\n            <div class=\"image-wrapper\">\n              <img src=\"@PROJECT_PATH@/assets/images/website-development-banner-free-vector-626x417.jpg\" alt=\"Mobirise Website Builder\" data-slide-to=\"2\" data-bs-slide-to=\"2\">\n            </div>\n\n            <div class=\"link-icon-wrapper\">\n              <svg class=\"svg1\" viewBox=\"0 0 100 100\">\n                <path d=\"m100,0H0v100C0,44.77,44.77,0,100,0Z\"></path>\n              </svg>\n\n              <div class=\"icon-wrap\">\n                <a href=\"index.html\"><span mbr-icon class=\"mbr-iconfont mbr-iconfont-btn mobi-mbri-right mobi-mbri\"></span></a>\n              </div>\n\n              <svg class=\"svg2\" viewBox=\"0 0 100 100\">\n                <path d=\"m100,0H0v100C0,44.77,44.77,0,100,0Z\"></path>\n              </svg>\n\n            </div>\n\n            <div class=\"item-content\" mbr-if=\"showCardTitle || showCardSubtitle || showText || showButtons\">\n              <h5 class=\"item-title mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".item-title\" mbr-if=\"showCardTitle\">\n                <b>WEB DEVELOPMENT</b></h5>\n              <h6 class=\"item-subtitle mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".item-subtitle\" mbr-if=\"showCardSubtitle\">\n                Subtitle</h6>\n              <p class=\"mbr-text mbr-fonts-style\" mbr-if=\"showText\" mbr-theme-style=\"display-7\" data-app-selector=\".mbr-text, .item .mbr-section-btn\">\n                Lorem ipsum dolor sit amet, consectetur adipiscing elit habitant turpis.\n              </p>\n            </div>\n            <h4 class=\"item-link mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".item-link\" mbr-if=\"showLink\">\n              <a href=\"#\" class=\"text-white\">Read more</a>\n            </h4>\n\n          </div>\n\n\n        </div>\n      </div>\n      \n      \n      \n\n\n    </div>\n  </div>\n</section>",
          "_cid": "uwzD17xZP1",
          "_anchor": "features1-2k",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "_name": "afeatures2",
          "_sourceTheme": "cyberm5",
          "_styles": {
            "padding-top": "(@paddingTop * 1rem)",
            "padding-bottom": "(@paddingBottom * 1rem)",
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            ".row": {
              "display": "flex",
              "align-items": "stretch",
              "justify-content": "center",
              "flex-wrap": "wrap"
            },
            ".mbr-section-title": {
              "color": "#010d4c"
            },
            ".mbr-section-subtitle": {
              "color": "#22a5e5",
              "opacity": "0.8",
              "text-align": "left"
            },
            ".card-title": {
              "color": "#010d4c",
              "margin-top": "30px",
              "a": {
                "font-weight": "700 !important",
                "&:hover": {
                  "text-decoration": "underline"
                }
              }
            },
            ".icon-box": {
              "display": "flex",
              "justify-content": "flex-start",
              ".mbr-iconfont": {
                "font-size": "45px",
                "color": "@iconColor"
              }
            },
            ".mbr-text": {
              "color": "#00284E",
              "opacity": "0.8",
              "margin-top": "16px"
            },
            ".icon-link-box": {
              "display": "flex",
              "justify-content": "flex-start",
              "margin-top": "16px",
              ".mbr-iconfont": {
                "font-size": "37px",
                "color": "@linkColor",
                "transition": "all 0.3s ease-in-out",
                "&:hover": {
                  "transform": "scale(1.1)",
                  "cursor": "pointer !important"
                }
              }
            },
            ".col-card": {
              "margin-top": "30px"
            },
            ".card-wrapper": {
              "padding": "52px 40px 45px 50px",
              "height": "100%",
              "@media (max-width: 1199px)": {
                "padding": "40px 20px 20px"
              }
            },
            "@media (min-width: 768px)": {
              ".card-1": {
                "& when not (@cardsAmount = '1')": {
                  "padding-left": "0",
                  "margin-right": "8px"
                }
              }
            },
            "& when (@activeCard)": {
              ".card-2": {
                "background": "@activeCardColor",
                "box-shadow": "0 30px 60px rgba(0, 19, 87, 0.04)",
                "border-radius": "15px"
              }
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            ".mbr-text, .link": {
              "color": "#ffffff"
            },
            ".card-title, .card-box": {
              "color": "#e6c63b",
              "text-align": "center"
            }
          },
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"features2\" group=\"Features\" data-bg-video=\"{{bg.type == 'video' && bg.value.url}}\" mbr-class=\"{'mbr-parallax-background': bg.parallax}\" plugins=\"mobirise-icons2\">\n\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\">\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"9\" step=\"1\" value=\"3\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"9\" step=\"1\" value=\"3\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showMainTitle\">\n        <input type=\"checkbox\" title=\"Subtitle\" name=\"showMainSubtitle\" checked>\n        <header>Card</header>\n        <input type=\"checkbox\" title=\"Active Card\" name=\"activeCard\" checked>\n        <input type=\"color\" title=\"Active Card Color\" name=\"activeCardColor\" value=\"#22a5e5\" condition=\"activeCard\">\n        <input type=\"checkbox\" title=\"Icon\" name=\"showIcon\" checked>\n        <input type=\"color\" title=\"Icon Color\" name=\"iconColor\" value=\"#913BFF\" condition=\"showIcon\">\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\" checked>\n        <input type=\"checkbox\" title=\"Link\" name=\"showLink\">\n        <input type=\"color\" title=\"Link Color\" name=\"linkColor\" value=\"#CECECE\" condition=\"showLink\">\n        <select title=\"Cards\" name=\"cardsAmount\">\n            <option value=\"1\">1</option>\n            <option value=\"2\">2</option>\n            <option value=\"3\" selected>3</option>\n        </select>\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"@PROJECT_PATH@/assets/images/background1-2.jpg\">\n            <input type=\"color\" title=\"Color\" value=\"#060606\" selected>\n            <input type=\"video\" title=\"Video\" value=\"https://vimeo.com/428046504\">\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"@PROJECT_PATH@/assets/images/background1-2.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#ffffff\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.5\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n\n\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type!== 'color'\" mbr-style=\"{'opacity': overlayOpacity, 'background-color': overlayColor}\">\n    </div>\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"mbr-section-head mb-3\" mbr-if=\"showMainTitle || showMainSubtitle\">\n            <div class=\"col-12\">\n                <h4 class=\"mbr-section-title mbr-fonts-style align-center mb-0\" mbr-theme-style=\"display-2\" mbr-if=\"showMainTitle\" data-app-selector=\".mbr-section-title\">\n                    Features\n                </h4>\n                <h5 class=\"mbr-section-subtitle mbr-fonts-style align-center mb-0 mt-2\" mbr-theme-style=\"display-7\" mbr-if=\"showMainSubtitle\" data-app-selector=\".mbr-section-subtitle\"><b>⭐&nbsp; Mobile Apps, E-Com and IT Software Development Services 📲</b></h5>\n            </div>\n        </div>\n        <div class=\"row\">\n            <div class=\"col-12 col-md-6 col-card\" mbr-class=\"{'col-lg-6': cardsAmount == '1',\n                                                     'col-lg-6': cardsAmount == '2',\n                                                     'col-lg-4': cardsAmount == '3'}\">\n                <div class=\"card-wrapper card-1\" mbr-if=\"showTitle || showText || showLink || showIcon\">\n                    <div class=\"card-box align-left\">\n                        <div class=\"icon-box\" mbr-if=\"showIcon\">\n                            <span mbr-icon class=\"mbr-iconfont mobi-mbri-growing-chart mobi-mbri\" style=\"color: rgb(34, 165, 229); fill: rgb(34, 165, 229);\"></span>\n                        </div>\n                        <h4 class=\"card-title mbr-fonts-style align-left mb-0\" mbr-theme-style=\"display-7\" mbr-if=\"showTitle\" data-app-selector=\".card-title, .card-box\"><b>MOBILE APP DEVELOPMENT</b></h4>\n                        <p class=\"mbr-text mbr-fonts-style mb-0\" mbr-theme-style=\"display-4\" mbr-if=\"showText\" data-app-selector=\".mbr-text, .link\">We are able to offer Mobile Application Development services as a natural extension of our business. We are also specialized in designing your website to have a good blend of integrated marketing, advertising and design. This helps to build distinct, highly effective strategies for a specific market segment and brand building. We balance offshore web design, offshore custom web technology with business intelligence to build interesting and effective market-building solutions for our clients.&nbsp;<br></p>\n                        <div class=\"icon-link-box\" mbr-if=\"showLink\">\n                            <span mbr-icon class=\"mbr-iconfont mobi-mbri-right mobi-mbri\"></span>\n                        </div>\n                    </div>\n                </div>\n            </div>\n\n            <div class=\"col-12 col-md-6 col-card\" mbr-if=\"cardsAmount > 1\" mbr-class=\"{'col-lg-6': cardsAmount == '2', 'col-lg-4': cardsAmount == '3'}\">\n                <div class=\"card-wrapper card-2\" mbr-if=\"showTitle || showText || showLink || showIcon\">\n                    <div class=\"card-box align-left\">\n                        <div class=\"icon-box\" mbr-if=\"showIcon\">\n                            <span mbr-icon class=\"mbr-iconfont mobi-mbri-contact-form mobi-mbri\" style=\"color: rgb(230, 198, 59); fill: rgb(230, 198, 59);\"></span>\n                        </div>\n                        <h4 class=\"card-title mbr-fonts-style align-left mb-0\" mbr-theme-style=\"display-7\" mbr-if=\"showTitle\" data-app-selector=\".card-title, .card-box\"><b>SOFTWARE DEVELOPMENT</b></h4>\n                        <p class=\"mbr-text mbr-fonts-style mb-0\" mbr-theme-style=\"display-4\" mbr-if=\"showText\" data-app-selector=\".mbr-text, .link\">Mobile technologies have become an important platform to conduct business, generate leads and support operations. Mobile platforms are changing very rapidly, as new devices, uses and operating systems have been introduced by the market. With our experience building standards-based web sites, our track record for customer service, and our involvement in the Open Source community.&nbsp;<br></p>\n                        <div class=\"icon-link-box\" mbr-if=\"showLink\">\n                            <span mbr-icon class=\"mbr-iconfont mobi-mbri-right mobi-mbri\"></span>\n                        </div>\n                    </div>\n                </div>\n            </div>\n            <div class=\"col-12 col-md-6 col-card\" mbr-if=\"cardsAmount > 2\" mbr-class=\"{'col-lg-4': cardsAmount == '3'}\">\n                <div class=\"card-wrapper card-3\" mbr-if=\"showTitle || showText || showLink || showIcon\">\n                    <div class=\"card-box align-left\">\n                        <div class=\"icon-box\" mbr-if=\"showIcon\">\n                            <span mbr-icon class=\"mbr-iconfont mobi-mbri-delivery mobi-mbri\" style=\"color: rgb(34, 165, 229); fill: rgb(34, 165, 229);\"></span>\n                        </div>\n                        <h4 class=\"card-title mbr-fonts-style align-left mb-0\" mbr-theme-style=\"display-7\" mbr-if=\"showTitle\" data-app-selector=\".card-title, .card-box\"><b>E-COMMERCE DEVELOPMENT</b></h4>\n                        <p class=\"mbr-text mbr-fonts-style mb-0\" mbr-theme-style=\"display-4\" mbr-if=\"showText\" data-app-selector=\".mbr-text, .link\">Each website is designed and developed keeping in mind how it can effectively reach out to its target audience, how comprehensively it can establish connections and interactivity and how successfully it can achieve its goals – be it creating a convincing web presence for the client or selling products or services. Every website is a work of intense thought and dedicated effort. This helps to build distinct, highly effective strategies for a specific market segment and brand building.&nbsp;<br></p>\n                        <div class=\"icon-link-box\" mbr-if=\"showLink\">\n                            <span mbr-icon class=\"mbr-iconfont mobi-mbri-right mobi-mbri\"></span>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_anchor": "afeatures2-9t",
          "_isUserblock": true,
          "_cid": "uW6neQYLc7",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
