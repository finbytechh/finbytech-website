        },
        {
          "_name": "article06",
          "_sourceTheme": "essencem5",
          "_styles": {
            "& when not (@fullScreen)": {
              "padding-top": "(@paddingTop * 1rem)",
              "padding-bottom": "(@paddingBottom * 1rem)"
            },
            "overflow": "hidden",
            "&::before": {
              "content": "''",
              "position": "absolute",
              "bottom": "0",
              "width": "200vh",
              "height": "25%",
              "background-image": "linear-gradient(transparent, @shadow 50%)",
              "z-index": "1"
            },
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            "& when (@fullWidth)": {
              ".container-fluid": {
                "padding": "0 80px",
                "@media (max-width: 1200px)": {
                  "padding": "0 40px"
                },
                "@media (max-width: 992px)": {
                  "padding": "0 22px"
                }
              }
            },
            ".container": {
              "@media (max-width: 992px)": {
                "padding": "0 22px"
              }
            },
            ".row": {
              "justify-content": "center"
            },
            ".content-wrapper": {
              "position": "relative",
              "z-index": "1",
              "padding": "100px 0",
              "@media (max-width: 992px)": {
                "padding": "0"
              },
              ".mbr-section-title": {
                "margin-bottom": "0"
              },
              ".mbr-desc": {
                "margin-bottom": "10px"
              }
            },
            ".mbr-section-title": {
              "color": "#ffffff"
            },
            ".mbr-desc": {
              "color": "#ffffff",
              "text-align": "center"
            },
            ".mbr-section-title, .mbr-section-btn": {
              "text-align": "center"
            }
          },
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"article06 essencem5\" group=\"Article\" mbr-class=\"{\n    'mbr-fullscreen': fullScreen,\n    'mbr-parallax-background': bg.parallax}\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Screen\" name=\"fullScreen\">\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\">\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"12\" step=\"1\" value=\"7\" condition=\"fullScreen == false\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"12\" step=\"1\" value=\"0\" condition=\"fullScreen == false\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Description\" name=\"showDesc\">\n        <input type=\"checkbox\" title=\"Buttons\" name=\"showButtons\">\n        <input type=\"color\" title=\"Shadow Color\" name=\"shadow\" value=\"#000000\">\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"@PROJECT_PATH@/assets/images/strategy-506x152.jpg\" parallax selected>\n            <input type=\"color\" title=\"Color\" value=\"#000000\">\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"@PROJECT_PATH@/assets/images/background1-6.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#000000\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.6\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row\">\n            <div class=\"col-12 col-lg-10\">\n                <div class=\"content-wrapper\">\n                    <h2 class=\"mbr-section-title mbr-fonts-style\" data-app-selector=\".mbr-section-title, .mbr-section-btn\" mbr-theme-style=\"display-2\" mbr-if=\"showTitle\"><b>Home / API Bridge pricing</b></h2>\n                    <p class=\"mbr-desc mbr-fonts-style\" data-app-selector=\".mbr-desc\" mbr-theme-style=\"display-7\" mbr-if=\"showDesc\">\n                        Write to us and subscribe on our social networks\n                    </p>\n                    <div mbr-buttons mbr-theme-style=\"display-4\" class=\"mbr-section-btn\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\">\n                        <a class=\"btn btn-secondary\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">\n                            Сontact now\n                        </a>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_anchor": "article06-5m",
          "_isUserblock": true,
          "_cid": "uwJCtsnW35",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "_name": "pricing01",
          "_sourceTheme": "digitalm4",
          "_customHTML": "<section data-bs-version=\"5.1\" group=\"Pricing Tables\" class=\"pricing01 digitalm4_pricing01\" data-bg-video=\"{{bg.type == 'video' && bg.value.url}}\" mbr-class=\"{'mbr-parallax-background':bg.parallax}\">\n\n    <mbr-parameters>\n        \n        <input inline type=\"range\" title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"8\" step=\"1\" value=\"2\">\n        <input inline type=\"range\" title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"8\" step=\"1\" value=\"0\">\n        <header>Show / Hide</header>\n        <input type=\"checkbox\" title=\"Badge\" name=\"showBadge\" checked>\n        <input type=\"checkbox\" title=\"Subtitle\" name=\"showSubtitle\">\n        <input type=\"checkbox\" title=\"Main Title\" name=\"showMainTitle\" checked>\n        <input type=\"checkbox\" title=\"Main Text\" name=\"showMainText\" checked>\n        <input type=\"checkbox\" title=\"Buttons\" name=\"showButtons\" checked>\n        <select title=\"Items Count\" name=\"itemsCount\">\n            <option value=\"1\">1</option>\n            <option value=\"2\">2</option>\n            <option value=\"3\" selected>3</option>\n        </select>\n        <input type=\"color\" title=\"Badge Bg Color\" name=\"badgeBg\" value=\"#848abd\" selected condition=\"showBadge\">\n        <input type=\"checkbox\" title=\"Bg Gradient\" name=\"gradientBg\" checked>\n\n        <input type=\"range\" inline title=\"Half BG Height\" name=\"halfHeight\" min=\"20\" max=\"150\" step=\"5\" value=\"50\">\n        <input type=\"color\" title=\"Half BG Color\" name=\"half\" value=\"#12566a\">\n        <input type=\"color\" title=\"Half BG Color 2\" name=\"half2\" value=\"#611750\" condition=\"gradientBg\">\n        <input type=\"color\" title=\"Price Bg Color\" name=\"priceBg\" value=\"#ffffff\">\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Background Image\" value=\"@ADDONS_PATH@/digitalm4/components/_images/background2.jpg\">\n            <input type=\"color\" title=\"Background Color\" value=\"#ffffff\" selected>\n            <input type=\"video\" title=\"Background Video\" value=\"https://www.youtube.com/watch?v=36YgDDJ7XSc\">\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"@ADDONS_PATH@/digitalm4/components/_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#ffffff\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.5\" condition=\"overlay && bg.type !== 'color'\">\n        \n    </mbr-parameters>\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n\n\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type!== 'color'\" mbr-style=\"{'opacity': overlayOpacity, 'background-color': overlayColor}\">\n    </div>\n\n    <div class=\"back\"></div>\n\n    <div class=\"container\">\n        <div class=\"badge_wrap align-center\">\n            <h5 class=\"badge mbr-regular mbr-bold mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".badge, .badge_wrap\" mbr-if=\"showBadge\">API PRICING\n            </h5>\n        </div>\n        <h3 class=\"mbr-fonts-style mbr-section-subtitle align-center mbr-light pt-3\" mbr-theme-style=\"display-4\" mbr-if=\"showSubtitle\" data-app-selector=\".mbr-section-subtitle\">\n            OUR PRICING</h3>\n        <h4 class=\"main-title align-center mbr-regular mbr-black mbr-fonts-style\" mbr-theme-style=\"display-2\" data-app-selector=\".main-title\" mbr-if=\"showMainTitle\">DIFFERENT NEED DIFFERENT PLANS</h4>\n\n        <p class=\"main-text align-center mbr-regular mbr-black mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".main-text\" mbr-if=\"showMainText\">Each plan can be priced competitively based on the features and resources included, with options for monthly or annual subscriptions. Additionally, you can offer tiered pricing structures with discounts for long-term commitments or volume-based pricing for institutional clients.\n<br>\n<br></p>\n        <div class=\"row\">\n            <div class=\"col-lg-12\">\n                <div class=\"media-container-row\">\n                    <div class=\"plan col-12 my-3 justify-content-center\" mbr-if=\"itemsCount > 0\" mbr-class=\"{\n                        'col-md-4': itemsCount == 3,\n                        'col-md-6': itemsCount == 2}\">\n                        <div class=\"plan-header text-center\">\n                            <div class=\"plan-price\">\n                                <div class=\"price-figure pb-1 mbr-fonts-style\" data-app-selector=\".plan .plan-header .plan-price .price-figure\">\n                                    <span mbr-text class=\"price-currency mbr-fonts-style\" mbr-theme-style=\"display-7\"><b>INR</b></span>\n                                    <span mbr-text class=\"price-value mbr-fonts-style mbr-semibold\" mbr-theme-style=\"display-1\">12999</span>\n                                    <span mbr-text class=\"price-duration mbr-fonts-style\" mbr-theme-style=\"display-4\">/&nbsp; <b>30 Days</b></span></div>\n                            </div>\n                            <h3 class=\"plan-title mbr-bold pb-3 mbr-fonts-style\" mbr-theme-style=\"display-5\" data-app-selector=\".plan .plan-header .plan-title\">Starter Plan</h3>\n                        </div>\n                        <div class=\"plan-body\">\n                            <div class=\"plan-list align-center\">\n                                <ul mbr-text class=\"list-group list-group-flush mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".plan .plan-body .plan-list .list-group .list-group-item, .plan .plan-body .mbr-section-btn\">\n                                    <li class=\"list-group-item\">Completely Automated</li><li class=\"list-group-item\"><br></li>\n                                    <li class=\"list-group-item\">Trade Indices</li><li class=\"list-group-item\"><br></li>\n                                    <li class=\"list-group-item\">3 Pre-loaded Strategy</li><li class=\"list-group-item\"><br></li>\n                                    <li class=\"list-group-item\">1 Strategy of API Coding</li><li class=\"list-group-item\"><br></li>\n                                    <li class=\"list-group-item\">Remote Support</li>\n                                    <li class=\"list-group-item\"><br></li><br><br><br><br><br><br><br><br><br><li class=\"list-group-item\"><br></li><br><br><br><br><br><br><li class=\"list-group-item\"><br></li><br><li class=\"list-group-item\"><br></li>\n                                </ul>\n                            </div>\n                            <div mbr-buttons mbr-theme-style=\"display-4\" class=\"mbr-section-btn\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\"><a href=\"Payment.html\" class=\"btn btn-sm btn-primary\" data-app-placeholder=\"Type Text\">Purchase Now</a></div>\n                        </div>\n                    </div>\n\n                    <div class=\"plan col-12 my-3 justify-content-center\" mbr-if=\"itemsCount > 1\" mbr-class=\"{\n                        'col-md-4': itemsCount == 3,\n                        'col-md-6': itemsCount == 2}\">\n                        <div class=\"plan-header text-center\">\n                            <div class=\"plan-price\">\n                                <div class=\"price-figure pb-1 mbr-fonts-style\" data-app-selector=\".price-figure\">\n                                    <span mbr-text class=\"price-currency mbr-fonts-style\" mbr-theme-style=\"display-7\"><b>INR</b></span>\n                                    <span mbr-text class=\"price-value mbr-fonts-style mbr-semibold\" mbr-theme-style=\"display-1\">33999</span>\n                                    <span mbr-text class=\"price-duration mbr-fonts-style\" mbr-theme-style=\"display-4\">/\n                                        <b>90 days</b></span></div>\n                            </div>\n                            <h3 class=\"plan-title mbr-bold pb-3 mbr-fonts-style\" mbr-theme-style=\"display-5\" data-app-selector=\".plan .plan-header .plan-title\">Quarterly Plan</h3>\n                        </div>\n                        <div class=\"plan-body\">\n                            <div class=\"plan-list align-center\">\n                                <ul mbr-text class=\"list-group list-group-flush mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".plan .plan-body .plan-list .list-group .list-group-item, .plan .plan-body .mbr-section-btn\">\n                                    <li class=\"list-group-item\">Completely Automated</li><li class=\"list-group-item\"><b><br></b></li>\n                                    <li class=\"list-group-item\">All Trade Indices</li><li class=\"list-group-item\"><b><br></b></li>\n                                    <li class=\"list-group-item\">3 Strategy of API Coding</li><li class=\"list-group-item\"><b><br></b></li>\n                                    <li class=\"list-group-item\">3 Demo Strategies for testing</li><li class=\"list-group-item\"><b><br></b></li><li class=\"list-group-item\">Strategy Change Approval</li><li class=\"list-group-item\"><b><br></b></li>WhatsApp, Call and Email Support<br><li class=\"list-group-item\"><br></li><li class=\"list-group-item\">MAINTAINANCE INR. 999/- </li><br><li class=\"list-group-item\">(EXCLUDING) Taxes will be Applicable on Every Month.</li><br><li class=\"list-group-item\">FOR (ALICE BLUE) MONTHLY MAINTAINANCE&nbsp;</li><br><li class=\"list-group-item\"> (Exclusive 50% OFF ) INR. 499 Discount ONLY For Alice-Blue Demat account Holders.</li><br><br><br><br><br><li class=\"list-group-item\"><br></li><li class=\"list-group-item\"><br></li>\n                                </ul>\n                            </div>\n                            <div mbr-buttons mbr-theme-style=\"display-4\" class=\"mbr-section-btn\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\"><a href=\"Payment.html\" class=\"btn btn-sm btn-primary\" data-app-placeholder=\"Type Text\">Purchase Now</a></div>\n                        </div>\n                    </div>\n\n                    <div class=\"plan col-12 my-3 justify-content-center\" mbr-if=\"itemsCount > 2\" mbr-class=\"{\n                        'col-md-4': itemsCount == 3,\n                        'col-md-6': itemsCount == 2}\">\n                        <div class=\"plan-header text-center\">\n                            <div class=\"plan-price\">\n                                <div class=\"price-figure pb-1 mbr-fonts-style\" data-app-selector=\".price-figure\">\n                                    <span mbr-text class=\"price-currency mbr-fonts-style\" mbr-theme-style=\"display-7\"><b>INR</b></span>\n                                    <span mbr-text class=\"price-value mbr-fonts-style mbr-semibold\" mbr-theme-style=\"display-1\">64999</span>\n                                    <span mbr-text class=\"price-duration mbr-fonts-style\" mbr-theme-style=\"display-4\">/ <b>180 days</b></span></div>\n                            </div>\n                            <h3 class=\"plan-title mbr-bold pb-3 mbr-fonts-style\" mbr-theme-style=\"display-5\" data-app-selector=\".plan .plan-header .plan-title\">Premium Plan</h3>\n                        </div>\n                        <div class=\"plan-body\">\n                            <div class=\"plan-list align-center\">\n                                <ul mbr-text class=\"list-group list-group-flush mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".plan .plan-body .plan-list .list-group .list-group-item, .plan .plan-body .mbr-section-btn\">\n                                    <li class=\"list-group-item\">Completely Automated</li><li class=\"list-group-item\"><b><br></b></li>\n                                    <li class=\"list-group-item\">Trade Indices with Option Chain</li><li class=\"list-group-item\"><b><br></b></li>\n                                    <li class=\"list-group-item\">6 Strategy of API Coding</li><li class=\"list-group-item\"><b><br></b></li>\n                                    <li class=\"list-group-item\">6 Demo Strategies for testing</li><br><li class=\"list-group-item\">Strategy Change Approval\n</li><li class=\"list-group-item\"><b><br></b></li>\n                                    <li class=\"list-group-item\">Dedicated Account Manager</li><li class=\"list-group-item\"><b><br></b></li>\n                                    <li class=\"list-group-item\">WhatsApp, Call and Email Support</li><li class=\"list-group-item\">\n</li><li class=\"list-group-item\">Access to Exclusive Webinars</li><b><br></b><li class=\"list-group-item\">MAINTAINANCE INR. 999/- </li><br><li class=\"list-group-item\">(EXCLUDING) Taxes will be Applicable on Every Month.</li><br><li class=\"list-group-item\">FOR (ALICE BLUE) MONTHLY MAINTAINANCE</li><br><li class=\"list-group-item\"><br></li><li class=\"list-group-item\"> (Exclusive 50% OFF ) INR. 499 Discount ONLY For Alice-Blue demat account Holders.</li>\n                                </ul>\n                            </div>\n                            <div mbr-buttons mbr-theme-style=\"display-4\" class=\"mbr-section-btn\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\"><a href=\"Payment.html\" class=\"btn btn-sm btn-primary\" data-app-placeholder=\"Type Text\">Purchase Now</a></div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_styles": {
            "padding-top": "(@paddingTop * 15px)",
            "padding-bottom": "(@paddingBottom * 15px)",
            "& when (@bg-type = \"color\")": {
              "background": "@bg-value"
            },
            "& when (@bg-type = \"image\")": {
              "background-image": "url(@bg-value)"
            },
            "& when (@gradientBg)": {
              ".back": {
                "background": "linear-gradient(45deg, @half, @half2)"
              }
            },
            "& when (@itemsCount = \"3\")": {
              ".plan": {
                "&:first-child": {
                  "padding-top": "20px",
                  "@media (max-width: 768px)": {
                    "padding-top": "0px"
                  },
                  ".plan-header": {
                    "border-radius": "4px 0 0 0"
                  },
                  ".plan-body": {
                    "border-radius": "0 0 4px 4px"
                  }
                },
                "&:last-child": {
                  "padding-top": "20px",
                  "@media (max-width: 768px)": {
                    "padding-top": "0px"
                  },
                  ".plan-header": {
                    "border-radius": "0 4px 0 0"
                  },
                  ".plan-body": {
                    "border-radius": "0 0 4px 4px"
                  }
                },
                "&:nth-child(2)": {
                  ".plan-header": {
                    "border-radius": "4px 4px 0 0"
                  }
                }
              }
            },
            ".badge": {
              "display": "inline-block",
              "border-radius": "10rem",
              "padding": "8px 14px 6px 14px",
              "color": "@primaryColor",
              "background-color": "fade(@badgeBg, 15%)",
              "margin-bottom": "26px"
            },
            ".badge.display-4": {
              "font-size": "11px",
              "line-height": "1.81",
              "letter-spacing": "0.5px"
            },
            ".back": {
              "position": "absolute",
              "top": "0",
              "left": "0",
              "width": "100%",
              "height": "~\"@{halfHeight}%\"",
              "background-color": "@half"
            },
            ".mbr-section-subtitle": {
              "color": "#ffffff",
              "font-weight": "600",
              "margin-bottom": "21px"
            },
            ".main-title": {
              "margin-bottom": "36px",
              "color": "#ffffff",
              "&.display-2": {
                "line-height": "1.375"
              }
            },
            ".main-text": {
              "color": "#ffffff",
              "&.display-4": {
                "line-height": "1.75"
              }
            },
            ".plan": {
              "word-break": "break-word",
              "display": "flex",
              "flex-direction": "column",
              "height": "fit-content",
              "position": "relative",
              "max-width": "330px",
              "padding-right": "0",
              "padding-left": "0",
              "transition": "all 0.3s",
              "border-radius": "4px",
              ".plan-header, .plan-body": {
                "background-color": "@priceBg"
              },
              ".plan-header": {
                "padding-top": "60px",
                "padding-left": "1rem",
                "padding-right": "1rem",
                ".plan-title": {
                  "color": "#000000"
                },
                ".plan-price": {
                  ".price-figure": {
                    "color": "#404040",
                    ".price-currency": {
                      "display": "inline-block",
                      "&.display-7": {
                        "font-size": "18px",
                        "line-height": "1"
                      }
                    },
                    ".price-value": {
                      "display": "inline-block",
                      "&.display-1": {
                        "font-size": "60px",
                        "line-height": "1"
                      }
                    },
                    ".price-duration": {
                      "display": "inline-block",
                      "&.display-4": {
                        "font-size": "16px",
                        "line-height": "1"
                      }
                    }
                  }
                }
              },
              ".plan-body": {
                "padding-bottom": "2rem",
                "box-shadow": "0px 5px 20px rgba(0, 0, 0, 0.04)",
                ".plan-list": {
                  ".list-group": {
                    ".list-group-item": {
                      "background-color": "@priceBg",
                      "position": "relative",
                      "-webkit-justify-content": "center",
                      "justify-content": "center",
                      "border": "0",
                      "color": "#606060",
                      "padding-top": "5px",
                      "padding-bottom": "5px",
                      "span": {
                        "font-weight": "600"
                      }
                    },
                    "&.display-4": {
                      "line-height": "1"
                    }
                  }
                },
                ".mbr-section-btn": {
                  "padding-top": "45px",
                  "text-align": "center",
                  ".btn-sm": {
                    "padding": "0.6rem 4.4rem"
                  },
                  ".btn": {
                    "&.display-4": {
                      "font-size": "13px",
                      "line-height": "1"
                    },
                    "&-primary": {
                      "&:hover": {
                        "box-shadow": "0 0 0 5px rgba(132, 138, 189, 0.2) !important",
                        "-webkit-box-shadow": "0 0 0 5px rgba(132, 138, 189, 0.2) !important"
                      }
                    },
                    "padding": "18px 26px 16px"
                  }
                }
              }
            },
            "@media (max-width: 550px)": {
              ".price-figure": {
                "font-size": "4.25rem"
              }
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            ".plan .plan-body .plan-list .list-group .list-group-item, .plan .plan-body .mbr-section-btn": {
              "text-align": "center",
              "color": "#27394e"
            }
          },
          "_cid": "uwCoeTxur0",
          "_anchor": "pricing01-3h",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "alias": false,
          "_styles": {
            "padding-top": "(@paddingTop * 1rem)",
            "padding-bottom": "(@paddingBottom * 1rem)",
            "background-color": "@bgColor",
            ".line": {
              "background-color": "@lineColor",
              "align": "center",
              "height": "2px",
              "margin": "0 auto"
            },
            ".mbr-text": {
              "color": "#9a9a9a"
            }
          },
          "_name": "content6",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"content6\" group=\"Content\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\">\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"0\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"0\">\n        <input type=\"range\" name=\"textWidth\" title=\"Width\" min=\"4\" max=\"12\" value=\"10\" step=\"1\">\n        \n        <input type=\"color\" name=\"lineColor\" title=\"Color\" value=\"#6592e6\">\n        <header>Background</header>\n        <input type=\"color\" title=\"Color\" name=\"bgColor\" value=\"#ffffff\">\n    </mbr-parameters>\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row justify-content-center\">\n            <div class=\"col-md-12 col-lg-{{textWidth}}\">\n                <hr class=\"line\">\n                <p class=\"mbr-text align-center mbr-fonts-style my-4\" mbr-theme-style=\"display-4\" data-app-selector=\".mbr-text\"><b>Note: Our Services Exclusively Listed without GST for Clear Understanding and Easy Comparison.18% GST Will be applicable on all our subscriptions. </b><br></p>\n                <hr class=\"line\">\n            </div>\n        </div>\n    </div>\n</section>",
          "_cid": "uvBiifgBZW",
          "_anchor": "content6-1s",
          "_sourceTheme": "mobirise5",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "alias": "popup-builder",
          "_isSecondary": true,
          "typeCompatible": "!isAMP",
          "_styles": {
            "&.popup-builder": {
              "background-color": "#ffffff",
              ".modal": {
                "position": "relative",
                "display": "block",
                "z-index": "1"
              },
              ".modal-dialog": {
                "margin-top": "60px",
                "margin-bottom": "60px",
                "& when (@popupSize = '5')": {
                  "margin-top": "0",
                  "margin-bottom": "0",
                  "margin": "0",
                  "height": "100%"
                }
              }
            },
            ".modal-content, .modal-dialog": {
              "height": "auto"
            },
            ".form-wrapper": {
              ".input-group-btn": {
                "margin-right": "auto",
                "margin-left": "auto",
                ".btn": {
                  "margin": "0 !important"
                }
              },
              "@media (min-width: 769px)": {
                ".mbr-form": {
                  ".form-group, .input-group-btn": {
                    "padding": "0 .5rem"
                  }
                }
              }
            },
            ".card-img": {
              "width": "100%",
              "margin": "auto",
              "border-radius": "0"
            },
            ".mbr-figure": {
              "img": {
                "display": "block",
                "width": "100%",
                "-ms-flex-item-align": "center",
                "-ms-grid-row-align": "center",
                "-webkit-align-self": "center",
                "align-self": "center"
              }
            },
            ".mbr-text": {
              "text-align": "center"
            },
            ".pt-0": {
              "padding-top": "0 !important"
            },
            ".pb-0": {
              "padding-bottom": "0 !important"
            },
            ".form-content": {
              "-ms-flex-pack": "center",
              "justify-content": "center",
              "text-align": "center"
            },
            ".mbr-overlay": {
              "bottom": "0",
              "left": "0",
              "position": "absolute",
              "right": "0",
              "top": "0",
              "z-index": "0",
              "pointer-events": "none"
            },
            ".modal-open": {
              "overflow": "hidden"
            },
            ".modal-open .modal": {
              "overflow-x": "hidden",
              "overflow-y": "auto"
            },
            ".modal": {
              "position": "fixed",
              "top": "0",
              "left": "0",
              "z-index": "1050",
              "display": "none",
              "width": "100%",
              "height": "100%",
              "overflow": "hidden",
              "outline": "0"
            },
            ".modal-dialog": {
              "position": "relative",
              "width": "auto",
              "margin": ".5rem",
              "pointer-events": "none",
              "& when (@popupSize = '5')": {
                "max-width": "100%",
                "height": "100%",
                "margin": "0"
              }
            },
            ".modal.fade .modal-dialog": {
              "transition": "transform 0.3s ease-out, -webkit-transform 0.3s ease-out",
              "-webkit-transform": "translate(0, -50px)",
              "transform": "translate(0, -50px)"
            },
            ".modal.show .modal-dialog": {
              "-webkit-transform": "none",
              "transform": "none"
            },
            ".modal-dialog-centered": {
              "display": "flex",
              "-ms-flex-align": "center",
              "align-items": "center",
              "min-height": "~\"calc(100% - (.5rem * 2))\""
            },
            ".modal-dialog-centered::before": {
              "display": "block",
              "height": "~\"calc(100vh - (.5rem * 2))\"",
              "content": "\"\""
            },
            ".modal-content": {
              "background": "@cardBg",
              "position": "relative",
              "display": "flex",
              "-ms-flex-direction": "column",
              "flex-direction": "column",
              "width": "100%",
              "pointer-events": "auto",
              "background-clip": "padding-box",
