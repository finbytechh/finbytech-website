                  ".nav-link": {
                    "padding": "0 !important",
                    "margin": "0 0 20px !important",
                    "border-radius": "0",
                    "font-size": "76px",
                    "justify-content": "flex-start",
                    "&:hover": {
                      "background-color": "transparent",
                      "color": "@menuBorderColor !important",
                      "box-shadow": "none"
                    }
                  }
                }
              },
              ".mbr-section-btn": {
                "margin-top": "70px",
                "text-align": "left"
              },
              ".btn-container": {
                "display": "none"
              }
            },
            "@media (max-width: 991px)": {
              ".navbar-brand": {
                "max-width": "60% !important",
                "width": "100% !important",
                "padding-right": "0 !important"
              },
              ".navbar-collapse": {
                "max-width": "100%",
                "width": "100%",
                "margin-left": "0",
                "padding-top": "6vw"
              },
              ".navbar-nav": {
                "border": "none",
                "background": "transparent",
                "max-width": "100%",
                ".nav-item": {
                  "display": "list-item",
                  "margin": "0 !important",
                  ".nav-link": {
                    "padding": "0 !important",
                    "margin": "0 0 2.1vw !important",
                    "border-radius": "0",
                    "font-size": "7.6vw",
                    "justify-content": "flex-start",
                    "&:hover": {
                      "background-color": "transparent",
                      "color": "@menuBorderColor !important",
                      "box-shadow": "none"
                    }
                  }
                }
              },
              ".mbr-section-btn": {
                "margin-top": "6.9vw",
                "text-align": "left"
              },
              ".btn-container": {
                "display": "none"
              }
            },
            "@media (max-width: 767px)": {
              ".navbar-nav": {
                ".nav-item": {
                  ".nav-link": {
                    "margin": "0 0 3vw !important",
                    "font-size": "9.6vw",
                    "line-height": "1"
                  }
                }
              },
              ".mbr-section-btn": {
                "margin-top": "7.5vw"
              }
            },
            "@media (max-width: 575px)": {
              ".navbar-nav": {
                ".nav-item": {
                  ".nav-link": {
                    "margin": "0 0 5vw !important",
                    "font-size": "11vw",
                    "line-height": "1"
                  }
                }
              },
              ".mbr-section-btn": {
                "display": "flex",
                "flex-direction": "column",
                "align-items": "stretch",
                ".btn": {
                  "width": "auto",
                  "margin-left": "0",
                  "margin-right": "0"
                }
              }
            }
          },
          "_cid": "uWL7RbFuP1",
          "_PHPplaceholders": [],
          "_JSplaceholders": [],
          "_anchor": "amenu2-ce",
          "_protectedParams": [],
          "_global": true,
          "_once": "menu",
          "_params": {}
        },
        {
          "_name": "header01",
          "_sourceTheme": "emblemm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"header01 emblemm5\" group=\"Headers\" data-bg-video=\"{{bg.type == 'video' && bg.value.url}}\" mbr-class=\"{\n    'mbr-fullscreen': fullScreen,\n    'mbr-parallax-background': bg.parallax}\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Screen\" name=\"fullScreen\">\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\" checked>\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"12\" step=\"1\" value=\"5\" condition=\"fullScreen == false\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"12\" step=\"1\" value=\"0\" condition=\"fullScreen == false\">\n        <input type=\"checkbox\" title=\"Reverse\" name=\"reverseContent\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"color\" title=\"Title Gradient 1\" value=\"#22a5e5\" name=\"title_1\" condition=\"showTitle\">\n        <input type=\"color\" title=\"Title Gradient 2\" value=\"#ffffff\" name=\"title_2\" condition=\"showTitle\">\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\" checked>\n        <input type=\"checkbox\" title=\"Buttons\" name=\"showButtons\" checked>\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"@PROJECT_PATH@/assets/images/background1.jpg\">\n            <input type=\"color\" title=\"Color\" value=\"#000000\">\n            <input type=\"video\" title=\"Video\" value=\"https://youtu.be/ExL8jClroLQ?si=sjabbJOMox8H4YMD\" selected>\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"@PROJECT_PATH@/assets/images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Gradient Background\" name=\"gradientBg\" checked>\n        <input type=\"color\" title=\"Gradient Color\" name=\"gradientColor\" value=\"#000000\" condition=\"gradientBg\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#000000\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.8\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row\" mbr-class=\"{'flex-row-reverse' : reverseContent}\">\n            <div class=\"col-12 col-lg-8\">\n                <div class=\"content-wrapper\">\n                    <h2 class=\"mbr-section-title mbr-fonts-style\" data-app-selector=\".mbr-section-title, .mbr-section-btn\" mbr-theme-style=\"display-2\" mbr-if=\"showTitle\"><b>\"Master trading with ease—simplified, clear, and effective.\"</b></h2>\n                    <p class=\"mbr-text mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"showText\" data-app-selector=\".mbr-text\">Finbytech Academy stands out as the best stock market institute, providing simplified, to-the-point courses tailored for beginners starting their trading journey&nbsp;</p>\n                    <div mbr-buttons mbr-theme-style=\"display-4\" class=\"mbr-section-btn\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\"><a class=\"btn btn-success\" href=\"popup:#mbr-popup-cx\" data-app-placeholder=\"Type Text\" data-toggle=\"modal\" data-bs-toggle=\"modal\" data-target=\"#mbr-popup-cx\" data-bs-target=\"#mbr-popup-cx\"><span class=\"mobi-mbri mobi-mbri-play mbr-iconfont mbr-iconfont-btn\"></span>Enroll Now&nbsp;</a></div>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_styles": {
            "& when not (@fullScreen)": {
              "padding-top": "(@paddingTop * 1rem)",
              "padding-bottom": "(@paddingBottom * 1rem)"
            },
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            "& when (@gradientBg)": {
              "position": "relative",
              "&::before": {
                "content": "''",
                "position": "absolute",
                "top": "0",
                "left": "0",
                "width": "100%",
                "height": "100%",
                "background-image": "linear-gradient(10deg, @gradientColor 18%, transparent 90%, @gradientColor 100%)",
                "pointer-events": "none",
                "z-index": "1"
              }
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            ".content-wrapper": {
              "position": "relative",
              "z-index": "2",
              "margin-top": "260px",
              "@media (max-width: 992px)": {
                "margin-top": "0"
              },
              ".mbr-section-title": {
                "margin-bottom": "22px",
                "background-image": "linear-gradient(180deg, @title_1, @title_2)",
                "-webkit-background-clip": "text",
                "-webkit-text-fill-color": "transparent"
              },
              ".mbr-text": {
                "margin-bottom": "22px"
              }
            },
            ".mbr-section-title": {
              "color": "#ffffff"
            },
            ".mbr-text": {
              "color": "#ffffff"
            },
            ".mbr-section-title, .mbr-section-btn": {
              "color": "#98dee8"
            }
          },
          "_cid": "uWZhFBToID",
          "_anchor": "header01-cg",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "alias": "popup-builder",
          "_isSecondary": true,
          "typeCompatible": "!isAMP",
          "_styles": {
            "&.popup-builder": {
              "background-color": "#ffffff",
              ".modal": {
                "position": "relative",
                "display": "block",
                "z-index": "1"
              },
              ".modal-dialog": {
                "margin-top": "60px",
                "margin-bottom": "60px",
                "& when (@popupSize = '5')": {
                  "margin-top": "0",
                  "margin-bottom": "0",
                  "margin": "0",
                  "height": "100%"
                }
              }
            },
            ".modal-content, .modal-dialog": {
              "height": "auto"
            },
            ".form-wrapper": {
              ".input-group-btn": {
                "margin-right": "auto",
                "margin-left": "auto",
                ".btn": {
                  "margin": "0 !important"
                }
              },
              "@media (min-width: 769px)": {
                ".mbr-form": {
                  ".form-group, .input-group-btn": {
                    "padding": "0 .5rem"
                  }
                }
              }
            },
            ".card-img": {
              "width": "100%",
              "margin": "auto",
              "border-radius": "0"
            },
            ".mbr-figure": {
              "img": {
                "display": "block",
                "width": "100%",
                "-ms-flex-item-align": "center",
                "-ms-grid-row-align": "center",
                "-webkit-align-self": "center",
                "align-self": "center"
              }
            },
            ".mbr-text": {
              "text-align": "center"
            },
            ".pt-0": {
              "padding-top": "0 !important"
            },
            ".pb-0": {
              "padding-bottom": "0 !important"
            },
            ".form-content": {
              "-ms-flex-pack": "center",
              "justify-content": "center",
              "text-align": "center"
            },
            ".mbr-overlay": {
              "bottom": "0",
              "left": "0",
              "position": "absolute",
              "right": "0",
              "top": "0",
              "z-index": "0",
              "pointer-events": "none"
            },
            ".modal-open": {
              "overflow": "hidden"
            },
            ".modal-open .modal": {
              "overflow-x": "hidden",
              "overflow-y": "auto"
            },
            ".modal": {
              "position": "fixed",
              "top": "0",
              "left": "0",
              "z-index": "1050",
              "display": "none",
              "width": "100%",
              "height": "100%",
              "overflow": "hidden",
              "outline": "0"
            },
            ".modal-dialog": {
              "position": "relative",
              "width": "auto",
              "margin": ".5rem",
              "pointer-events": "none",
              "& when (@popupSize = '5')": {
                "max-width": "100%",
                "height": "100%",
                "margin": "0"
              }
            },
            ".modal.fade .modal-dialog": {
              "transition": "transform 0.3s ease-out, -webkit-transform 0.3s ease-out",
              "-webkit-transform": "translate(0, -50px)",
              "transform": "translate(0, -50px)"
            },
            ".modal.show .modal-dialog": {
              "-webkit-transform": "none",
              "transform": "none"
            },
            ".modal-dialog-centered": {
              "display": "flex",
              "-ms-flex-align": "center",
              "align-items": "center",
              "min-height": "~\"calc(100% - (.5rem * 2))\""
            },
            ".modal-dialog-centered::before": {
              "display": "block",
              "height": "~\"calc(100vh - (.5rem * 2))\"",
              "content": "\"\""
            },
            ".modal-content": {
              "background": "@cardBg",
              "position": "relative",
              "display": "flex",
              "-ms-flex-direction": "column",
              "flex-direction": "column",
              "width": "100%",
              "pointer-events": "auto",
              "background-clip": "padding-box",
              "border": "none",
              "outline": "0",
              "-webkit-box-shadow": "0 10px 40px 0 rgba(0, 0, 0, 0.2)",
              "box-shadow": "0 10px 40px 0 rgba(0, 0, 0, 0.2)",
              "& when (@popupSize = '5')": {
                "border-radius": "0",
                "height": "100%",
                "overflow": "auto"
              }
            },
            ".margin-center-pos": {
              "margin-top": "auto",
              "margin-bottom": "auto"
            },
            ".modal-backdrop": {
              "position": "fixed",
              "top": "0",
              "left": "0",
              "z-index": "1040",
              "width": "100vw",
              "height": "100vh",
              "background-color": "#000"
            },
            ".modal-backdrop.fade": {
              "opacity": "0"
            },
            ".modal-backdrop.show": {
              "opacity": ".5"
            },
            ".modal-header": {
              "display": "flex",
              "-ms-flex-align": "start",
              "align-items": "flex-start",
              "-ms-flex-pack": "justify",
              "justify-content": "space-between",
              "@media (min-width: 992px)": {
                "padding": "2rem 2rem 1rem"
              },
              "@media (max-width: 991px)": {
                "padding": "1rem"
              },
              "border-bottom": "none"
            },
            ".modal-header .close": {
              "position": "absolute",
              "top": "1rem",
              "right": "1rem",
              "margin": "-1rem -1rem -1rem auto",
              "padding": "1rem",
              "opacity": ".75",
              "svg": {
                "fill": "@closeButton"
              },
              "&:hover": {
                "opacity": "1"
              },
              "&:focus": {
                "outline": "none"
              }
            },
            ".modal-title": {
              "line-height": "1.5",
              "width": "100%",
              "margin": "0",
              "text-align": "center",
              "color": "#e6c63b"
            },
            ".modal-body": {
              "position": "relative",
              "-ms-flex": "1 1 auto",
              "flex": "1 1 auto",
              "@media (min-width: 992px)": {
                "padding": "1rem 2rem 2rem"
              },
              "@media (max-width: 991px)": {
                "padding": "1rem"
              }
            },
            ".modal-footer": {
              "display": "flex",
              "-ms-flex-align": "center",
              "align-items": "center",
              "-ms-flex-pack": "center",
              "justify-content": "center",
              "@media (min-width: 992px)": {
                "padding": "0rem 2rem 2rem"
              },
              "@media (max-width: 991px)": {
                "padding": "1rem"
              },
              "border-top": "none",
              "text-align": "center"
            },
            ".modal-scrollbar-measure": {
              "position": "absolute",
              "top": "-9999px",
              "width": "50px",
              "height": "50px",
              "overflow": "scroll"
            },
            "@media (min-width: 576px)": {
              ".modal-dialog": {
                "& when not (@popupSize = '5')": {
                  "max-width": "500px",
                  "margin": "1.75rem auto"
                }
              },
              ".modal-dialog-centered": {
                "min-height": "~\"calc(100% - (1.75rem * 2))\""
              },
              ".modal-dialog-centered::before": {
                "height": "~\"calc(100vh - (1.75rem * 2))\""
              },
              ".modal-sm": {
                "max-width": "300px"
              }
            },
            "@media (min-width: 992px)": {
              ".modal-lg, .modal-xl": {
                "max-width": "800px"
              }
            },
            "@media (min-width: 1200px)": {
              ".modal-xl": {
                "max-width": "1140px"
              }
            },
            ".row": {
              "display": "flex",
              "-ms-flex-wrap": "wrap",
              "flex-wrap": "wrap",
              "margin-right": "-15px",
              "margin-left": "-15px"
            },
            ".col-md-4": {
              "position": "relative",
              "width": "100%",
              "padding-right": "15px",
              "padding-left": "15px",
              "-ms-flex": "0 0 33.333333%",
              "flex": "0 0 33.333333%",
              "max-width": "33.333333%"
            },
            ".form-group": {
              "margin-bottom": "1rem"
            },
            ".form-control": {
              "display": "block",
              "width": "100%",
              "font-size": "1rem",
              "font-weight": "400",
              "line-height": "1.5"
            },
            ".col": {
              "-ms-flex-preferred-size": "0",
              "flex-basis": "0",
              "-ms-flex-positive": "1",
              "flex-grow": "1",
              "max-width": "100%"
            },
            ".col-md-auto": {
              "position": "relative",
              "padding-right": "15px",
              "padding-left": "15px",
              "-ms-flex": "0 0 auto",
              "flex": "0 0 auto",
              "width": "auto",
              "max-width": "100%"
            },
            ".mbr-section-btn": {
              "margin": "0",
              ".btn": {
                "margin": "0"
              }
            },
            "LABEL": {
              "color": "#e6c63b",
              "text-align": "left"
            }
          },
          "_name": "mbr-popup",
          "_sourceTheme": "mobirise5",
          "_customHTML": "<section class=\"popup-builder\" group=\"Popup\" plugins=\"formstyler, datepicker\">\n\n    <mbr-parameters>\n        <!-- Block parameters controls (Blue \"Gear\" panel) -->\n        <header>Triggers / Show Popup</header>\n        <label>On Click</label>\n        <label>Use [popup-id] with any link or button (Link -&gt; Popup tab)</label>\n        <input type=\"checkbox\" title=\"On Timer\" name=\"onTimer\">\n        <input type=\"range\" title=\"Delay (s)\" name=\"onTimerDelay\" min=\"0\" max=\"30\" step=\"1\" value=\"5\" condition=\"onTimer == true\">\n\n        <input type=\"checkbox\" title=\"On Page Exit\" name=\"onPageExit\">\n\n        <input type=\"checkbox\" title=\"On Scroll to End\" name=\"onScroll\">\n\n        <select title=\"Add to Pages:\" name=\"popupOnPages\" multiple condition=\"onTimer == true || onPageExit == true || onScroll == true\"></select>\n\n        <header>Content</header>\n        <input type=\"checkbox\" title=\"Show Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Show Text\" name=\"showText\">\n\n        <select title=\"Content Type\" name=\"popupContentType\">\n            <option value=\"1\">None</option>\n            <option value=\"2\">Image</option>\n            <option value=\"3\">Video</option>\n            <option value=\"4\" selected>Form</option>\n        </select>\n\n        <select title=\"Size\" name=\"popupSize\">\n            <option value=\"1\">Small</option>\n            <option value=\"2\" selected>Default</option>\n            <option value=\"3\">Large</option>\n            <option value=\"4\">Extra large</option>\n            <option value=\"5\">Full Screen</option>\n        </select>\n        <input type=\"checkbox\" title=\"Show Buttons\" name=\"showButtons\">\n\n        <input type=\"color\" title=\"Background Color\" name=\"cardBg\" value=\"#050f14\">\n        <input type=\"color\" title=\"Close Button\" name=\"closeButton\" value=\"#e43f3f\">\n\n        <header>Overlay</header>\n        <input type=\"color\" title=\"Color\" name=\"popupOverlayColor\" value=\"#000000\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.8\">\n        <!-- End block parameters -->\n    <input type=\"hidden\" name=\"usedRecaptcha\" value=\"false\"></mbr-parameters>\n\n    <div class=\"mbr-overlay\" mbr-style=\"{'opacity': overlayOpacity, 'background-color': popupOverlayColor, 'top': 0, 'right': 0, 'bottom': 0, 'left': 0, 'position': absolute, 'z-index': 0, 'pointer-events': none}\">\n    </div>\n\n    <div class=\"modal mbr-popup\" tabindex=\"-1\" role=\"dialog\" data-overlay-color=\"{{popupOverlayColor}}\" data-overlay-opacity=\"{{overlayOpacity}}\" data-on-timer-delay=\"{{onTimer ? onTimerDelay : ''}}\" data-on-exit=\"{{onPageExit}}\" data-on-scroll=\"{{onScroll}}\">\n        <div class=\"modal-dialog\" role=\"document\" mbr-class=\"{\n            'modal-sm': popupSize == 1,\n            '': popupSize == 2,\n            'modal-lg': popupSize == 3,\n            'modal-xl': popupSize == 4\n            }\">\n            <div class=\"modal-content\">\n                <div class=\"container position-static margin-center-pos\">\n                    <div class=\"modal-header\" mbr-class=\"{'pb-0': showTitle && showText}\">\n                        <h5 class=\"modal-title mbr-fonts-style\" mbr-theme-style=\"display-5\" data-app-selector=\".modal-title\" mbr-if=\"showTitle\"><b>Registration Form</b></h5>\n                        <button type=\"button\" class=\"close d-flex\" data-dismiss=\"modal\" data-bs-dismiss=\"modal\" aria-label=\"Close\">\n                            <svg version=\"1.1\" xmlns=\"http://www.w3.org/2000/svg\" width=\"23\" height=\"23\" viewBox=\"0 0 23 23\" fill=\"currentColor\">\n                                <path d=\"M13.4 12l10.3 10.3-1.4 1.4L12 13.4 1.7 23.7.3 22.3 10.6 12 .3 1.7 1.7.3 12 10.6 22.3.3l1.4 1.4L13.4 12z\">\n                                </path>\n                            </svg>\n                        </button>\n                    </div>\n\n                    <div class=\"modal-body\">\n                        <p class=\"mbr-text mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".mbr-text\" mbr-if=\"showText\">\n                            Lorem ipsum dolor sit amet, consectetur adipisicing elit. Tempore incidunt molestias, vitae\n                            recusandae error ipsam\n                        </p>\n\n                        <div mbr-if=\"popupContentType !== 1\">\n                            <div class=\"card-img mbr-figure\" mbr-if=\"popupContentType == 2\">\n                                <img src=\"../_images/popup.jpg\" alt=\"Mobirise\">\n                            </div>\n                            <div mbr-video class=\"video-block mbr-figure\" mbr-if=\"popupContentType == 3\">\n                                <iframe src=\"http://www.youtube.com/watch?v=uNCr7NdOJgw\"></iframe>\n                            </div>\n\n                            <div mbr-form mbr-if=\"popupContentType == 4\" class=\"form-wrapper\">\n<!--Formbuilder Form-->\n<form action=\"Dizyne.tech@gmail.com\" name=\"Mobirise Form\" method=\"POST\" class=\"mbr-form form-with-styler\" data-verified=\"Dizyne.tech@gmail.com\">\n<div class>\n<div hidden=\"hidden\" data-form-alert class=\"alert alert-success col-12\">Thanks for filling out the form!</div>\n<div hidden=\"hidden\" data-form-alert-danger class=\"alert alert-danger col-12\"> </div>\n</div>\n<div class=\"dragArea row\">\n<div class=\"col-lg-12 col-md-12 col-sm-12 form-group\" data-for=\"name\">\n<input type=\"text\" name=\"name\" placeholder=\"Name\" data-form-field=\"Name\" mbr-theme-style=\"display-7\" required=\"required\" class=\"form-control\" value>\n</div>\n<div class=\"col-lg-12 col-md-12 col-sm-12 form-group\" data-for=\"Number\">\n<input type=\"text\" name=\"Number\" placeholder=\"Mobile Number\" data-form-field=\"Number\" mbr-theme-style=\"display-7\" required=\"required\" class=\"form-control\" value>\n</div>\n<div data-for=\"Email\" class=\"col-lg-12 col-md-12 col-sm-12 form-group\">\n<input type=\"text\" name=\"Email\" placeholder=\"Email Address\" data-form-field=\"Email\" mbr-theme-style=\"display-7\" class=\"form-control\" required=\"required\" value>\n</div>\n<div data-for=\"City\" class=\"col form-group \">\n<input type=\"email\" name=\"City\" placeholder=\"City\" data-form-field=\"City\" mbr-theme-style=\"display-7\" class=\"form-control\" required=\"required\" value>\n</div>\n<div data-for=\"Remarks\" class=\"col-lg-12 col-md-12 col-sm-12 form-group\">\n<textarea name=\"Remarks\" placeholder=\"Remarks\" data-form-field=\"Remarks\" mbr-theme-style=\"display-7\" class=\"form-control\"></textarea>\n</div>\n<div class=\"col-lg-12 col-md-12 col-sm-12 form-group\" data-for=\"Interested to learn \">\n<label mbr-text mbr-theme-style=\"display-7\" for=\"Interested to learn \" class=\"form-control-label mbr-fonts-style\"><b>Interested to learn </b></label>\n<select name=\"Interested to learn \" data-form-field=\"Interested to learn \" mbr-theme-style=\"display-7\" class=\"form-control form-select\">\n<option value=\"Trading \">Trading </option>\n<option value=\"Investing \">Investing </option>\n</select>\n</div>\n<div mbr-buttons=\"true\" mbr-theme-style=\"display-4\" data-toolbar=\"-mbrBtnMove,-mbrLink,-mbrBtnRemove,-mbrBtnAdd\" class=\"col-md-auto input-group-btn\">\n<a data-toolbar=\"-mbrBtnMove,-mbrLink,-mbrBtnRemove,-mbrBtnAdd\" type=\"submit\" class=\"w-100 w-100 btn btn-success-outline\">Submit</a>\n</div>\n</div>\n</form><!--Formbuilder Form-->\n</div>\n                        </div>\n                    </div>\n\n                    <div class=\"modal-footer\" mbr-class=\"{'pt-0': popupContentType == 1 || popupContentType == 4}\" mbr-if=\"showButtons\">\n                        <div class=\"mbr-section-btn\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\" mbr-buttons mbr-theme-style=\"display-4\">\n                            <a class=\"btn btn-md btn-primary\" href=\"https://mobiri.se\">\n                                LEARN MORE\n                            </a>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n\n</section>",
          "_cid": "uXcrnS7IS6",
          "_anchor": "mbr-popup-cx",
          "_popupId": "mbr-popup-cx",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "_name": "article05",
          "_sourceTheme": "choicem5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"article05 choicem5\" group=\"Article\" mbr-class=\"{\n    'mbr-fullscreen': fullScreen,\n    'mbr-parallax-background': bg.parallax}\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Screen\" name=\"fullScreen\">\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\">\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"12\" step=\"1\" value=\"2\" condition=\"fullScreen == false\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"12\" step=\"1\" value=\"1\" condition=\"fullScreen == false\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\" checked>\n        <input type=\"checkbox\" title=\"Buttons\" name=\"showButtons\">\n        <input type=\"checkbox\" title=\"Decoration\" name=\"showDecor\">\n        <input type=\"color\" title=\"Decoration Border\" value=\"#cdcddd\" name=\"border\" condition=\"showDecor\" selected>\n        <input type=\"color\" title=\"Decoration Shadow\" value=\"#ffffff\" name=\"shadow\" condition=\"showDecor\" selected>\n        <header>Image</header>\n        <input type=\"color\" title=\"Border Color\" value=\"#000000\" name=\"cardBorder\" selected>\n        <input type=\"color\" title=\"Shadow\" value=\"#202020\" name=\"cardShadow\">\n        <input type=\"color\" title=\"BG 1\" value=\"#000000\" name=\"cardBg_1\" selected>\n        <input type=\"color\" title=\"BG 2\" value=\"#232323\" name=\"cardBg_2\" selected>\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"@ADDONS_PATH@/choicem5/components/_images/background1.jpg\">\n            <input type=\"color\" title=\"Color\" value=\"#000000\" selected>\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"@ADDONS_PATH@/choicem5/components/_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\">\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#ffffff\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.8\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n\n    <div class=\"decor-wrapper decoration_1\" mbr-if=\"showDecor\">\n        <div class=\"decor decor_1 middle-radius\"></div>\n    </div>\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row justify-content-center\">\n            <div class=\"col-12 col-lg-9\">\n                <div class=\"content-wrapper\">\n                    <h2 class=\"mbr-section-title mbr-fonts-style\" data-app-selector=\".mbr-section-title, .mbr-section-btn\" mbr-theme-style=\"display-5\" mbr-if=\"showTitle\"><b>\n                        Expertise That Delivers Value\n                    </b></h2>\n                    <div class=\"text-wrapper\">\n                        <p class=\"mbr-text mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"showText\" data-app-selector=\".mbr-text\"><b>\n                            \"Enhance your stock market journey with structured study materials designed by NISM-certified mentors.\"\n                        </b></p>\n                    </div>\n                    <div mbr-buttons mbr-theme-style=\"display-4\" class=\"mbr-section-btn\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\">\n                        <a class=\"btn btn-black\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">\n                            <span class=\"mobi-mbri mobi-mbri-right mbr-iconfont mbr-iconfont-btn\"></span>\n                            View more\n                        </a>\n                    </div>\n                    <div class=\"image-wrapper large-radius\">\n                        <div class=\"image-wrap middle-radius\">\n                            <img src=\"@PROJECT_PATH@/assets/images/chatgpt-image-sep-18-2025-01-48-15-am-1536x1024.png\" alt=\"Mobirise Website Builder\">\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n    <div class=\"decor-wrapper decoration_2\" mbr-if=\"showDecor\">\n        <div class=\"decor decor_2 middle-radius\"></div>\n    </div>\n</section>",
          "_styles": {
            "& when not (@fullScreen)": {
              "padding-top": "(@paddingTop * 1rem)",
              "padding-bottom": "(@paddingBottom * 1rem)"
            },
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            "& when (@showDecor)": {
              "position": "relative",
              "overflow": "hidden",
              ".decor-wrapper": {
                "position": "absolute",
                "top": "0",
                "height": "100%",
                "padding": "32px 0",
                ".decor": {
                  "height": "100%",
                  "width": "400px",
                  "border": "1px solid @border"
                },
                ".decor_1": {
                  "box-shadow": "inset 0 0 0 2px @shadow"
                },
                ".decor_2": {
                  "box-shadow": "inset 0 0 0 2px @shadow"
                }
              },
              ".decoration_1": {
                "left": "-100px",
                "@media (max-width: 1640px)": {
                  "left": "-230px"
                },
                "@media (max-width: 1440px)": {
                  "left": "-250px"
                },
                "@media (max-width: 1200px)": {
                  "left": "-300px"
                },
                "@media (max-width: 992px)": {
                  "left": "-380px"
                },
                "& when (@fullWidth)": {
                  "left": "-250px !important",
                  "@media (max-width: 1200px)": {
                    "left": "-300px !important"
                  },
                  "@media (max-width: 992px)": {
                    "left": "-380px !important"
                  }
                }
              },
              ".decoration_2": {
                "right": "-100px",
                "@media (max-width: 1640px)": {
                  "right": "-230px"
                },
                "@media (max-width: 1440px)": {
                  "right": "-250px"
                },
                "@media (max-width: 1200px)": {
                  "right": "-300px"
                },
                "@media (max-width: 992px)": {
                  "right": "-380px"
                },
                "& when (@fullWidth)": {
                  "right": "-250px !important",
                  "@media (max-width: 1200px)": {
                    "right": "-300px !important"
                  },
                  "@media (max-width: 992px)": {
                    "right": "-380px !important"
                  }
                }
              }
            },
            ".content-wrapper": {
              "position": "relative",
              "z-index": "1",
              "& when (@showDecor)": {
                "padding": "120px 0",
                "@media (max-width: 992px)": {
                  "padding": "0 16px"
                }
              },
              ".mbr-section-title": {
                "margin-bottom": "24px"
              },
              ".text-wrapper": {
                ".mbr-text": {
                  "display": "inline-block",
                  "width": "60%",
                  "margin-bottom": "0",
                  "@media (max-width: 992px)": {
                    "width": "100%"
                  }
                }
              },
              ".mbr-section-btn": {
                "margin-top": "32px",
                "@media (max-width: 992px)": {
                  "margin-top": "24px"
                }
              },
              ".image-wrapper": {
                "margin-top": "32px",
                "height": "100%",
                "padding": "12px",
                "border": "1px solid @cardBorder",
                "background-color": "@cardBg_1",
                "box-shadow": "0 .25rem .375rem #00000014",
                "@media (max-width: 992px)": {
                  "padding": "6px",
                  "margin-top": "24px"
                },
                ".image-wrap": {
                  "padding": "12px",
                  "background-color": "@cardBg_2",
                  "border": "1px solid @cardBorder",
                  "box-shadow": "0 0.25rem 0.375rem -0.125rem @cardShadow",
                  "height": "100%",
                  "overflow": "hidden",
                  "@media (max-width: 992px)": {
                    "padding": "6px"
                  },
                  "img": {
                    "height": "400px",
                    "object-fit": "cover",
                    "width": "100%",
                    "@media (max-width: 992px)": {
                      "height": "300px"
                    },
                    "@media (max-width: 768px)": {
                      "height": "250px"
                    }
                  }
                }
              }
            },
            ".mbr-label": {
              "color": "#49496d",
              "text-align": "center"
            },
            ".mbr-section-title": {
              "color": "#181824"
            },
            ".mbr-text, .text-wrapper": {
              "color": "#54547e",
              "text-align": "center"
            },
            ".mbr-section-title, .mbr-section-btn, .icon-wrapper": {
              "text-align": "center"
            },
            ".mbr-section-title, .mbr-section-btn": {
              "color": "#22a5e5",
              "text-align": "center"
            },
            ".mbr-text": {
              "color": "#ffffff"
            }
          },
          "_cid": "uX5un1aHDY",
          "_anchor": "article05-ch",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "_name": "features01",
          "_sourceTheme": "tokenm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"features01 tokenm5\" group=\"Features\" mbr-class=\"{\n    'mbr-fullscreen': fullScreen,\n    'mbr-parallax-background': bg.parallax}\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Screen\" name=\"fullScreen\">\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\" checked>\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"12\" step=\"1\" value=\"2\" condition=\"fullScreen == false\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"12\" step=\"1\" value=\"2\" condition=\"fullScreen == false\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\" checked>\n        <header>Cards</header>\n        <input type=\"checkbox\" title=\"Card Title\" name=\"showCardTitle\" checked>\n        <input type=\"checkbox\" title=\"Card Icon\" name=\"showIcon\" checked>\n        <input type=\"color\" title=\"Icon Color\" value=\"#000000\" name=\"icon\" condition=\"showIcon\">\n        <input type=\"checkbox\" title=\"Card Text\" name=\"showCardText\" checked>\n        <input type=\"checkbox\" title=\"Card Buttons\" name=\"showButtons\">\n        <input type=\"color\" title=\"Card BG\" value=\"#22a5e5\" name=\"cardBg\">\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"@ADDONS_PATH@/tokenm5/components/_images/background1.jpg\">\n            <input type=\"color\" title=\"Color\" value=\"#000000\" selected>\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"@ADDONS_PATH@/tokenm5/components/_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\">\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#000000\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.8\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row\">\n            <div class=\"col-12 col-lg-10\">\n                <div class=\"title-wrapper\" mbr-if=\"showTitle || showText\">\n                    <h2 class=\"mbr-section-title mbr-fonts-style\" data-app-selector=\".mbr-section-title, .mbr-section-btn\" mbr-theme-style=\"display-2\" mbr-if=\"showTitle\"><b>How you can&nbsp;</b><b style=\"font-size: 3rem;\">learn from us&nbsp;</b></h2>\n                    <div class=\"text-wrapper\">\n                        <p class=\"mbr-text mbr-fonts-style\" data-app-selector=\".mbr-text, .text-wrapper\" mbr-theme-style=\"display-4\" mbr-if=\"showText\">\"At Finbytech, our mission is to empower millions with the knowledge and skills to achieve true financial independence through stock market mastery. Become part of the thriving Finbytech community and take charge of your financial future!\"</p>\n                    </div>\n                </div>\n                <div class=\"items-wrapper\">\n                    \n                    <div class=\"item features-without-image active\">\n                        <div class=\"item-wrapper\">\n                            <div class=\"card-box\">\n                                <h4 class=\"card-title mbr-fonts-style\" mbr-theme-style=\"display-5\" mbr-if=\"showCardTitle\" data-app-selector=\".card-title, .iconfont-wrapper\">\n                                    <b> Online Classes</b></h4>\n                                <div class=\"iconfont-wrapper\" mbr-if=\"showIcon\">\n                                    <span mbr-icon class=\"mbr-iconfont mobi-mbri-play mobi-mbri\" style=\"color: rgb(255, 255, 255); fill: rgb(255, 255, 255);\"></span>\n                                </div>\n                                <p class=\"card-text mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"showCardText\" data-app-selector=\".card-text, .mbr-section-btn\">Over 300+ revision classes to help you cover any topic you miss in your live class. You will never be left behind.&nbsp;<br></p>\n                                <div class=\"mbr-section-btn\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\" mbr-buttons mbr-theme-style=\"display-4\">\n                                    <a href class=\"btn item-btn btn-secondary\" data-app-placeholder=\"Type Text\">\n                                        Read More\n                                    </a>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                    <div class=\"item features-without-image\">\n                        <div class=\"item-wrapper\">\n                            <div class=\"card-box\">\n                                <h4 class=\"card-title mbr-fonts-style\" mbr-theme-style=\"display-5\" mbr-if=\"showCardTitle\" data-app-selector=\".card-title, .iconfont-wrapper\">\n                                    <b>Seminars</b>\n                                </h4>\n                                <div class=\"iconfont-wrapper\" mbr-if=\"showIcon\">\n                                    <span mbr-icon class=\"mbr-iconfont mdi-notification-event-available\" style=\"color: rgb(255, 255, 255); fill: rgb(255, 255, 255);\"></span>\n                                </div>\n                                <p class=\"card-text mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"showCardText\" data-app-selector=\".card-text, .mbr-section-btn\">\"At Finbytech, our mission is to empower millions with the knowledge and skills to achieve true financial independence through stock market mastery. Become part of the thriving Finbytech community and take charge of your financial future!\"<br></p>\n                                <div class=\"mbr-section-btn\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\" mbr-buttons mbr-theme-style=\"display-4\">\n                                    <a href class=\"btn item-btn btn-secondary\" data-app-placeholder=\"Type Text\">\n                                        Read More\n                                    </a>\n                                </div>\n                            </div>\n                        </div>\n                    </div><div class=\"item features-without-image\">\n                        <div class=\"item-wrapper\">\n                            <div class=\"card-box\">\n                                <h4 class=\"card-title mbr-fonts-style\" mbr-theme-style=\"display-5\" mbr-if=\"showCardTitle\" data-app-selector=\".card-title, .iconfont-wrapper\">\n                                    <b>Offline Clases</b></h4>\n                                <div class=\"iconfont-wrapper\" mbr-if=\"showIcon\">\n                                    <span mbr-icon class=\"mbr-iconfont mobi-mbri-users mobi-mbri\" style=\"color: rgb(255, 255, 255); fill: rgb(255, 255, 255);\"></span>\n                                </div>\n                                <p class=\"card-text mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"showCardText\" data-app-selector=\".card-text, .mbr-section-btn\">We have Live Q/A interaction sessions with NISM Certified mentors with great market experience, where students ask their queries directly to him.&nbsp;<br></p>\n                                <div class=\"mbr-section-btn\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\" mbr-buttons mbr-theme-style=\"display-4\">\n                                    <a href class=\"btn item-btn btn-secondary\" data-app-placeholder=\"Type Text\">\n                                        Read More\n                                    </a>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_styles": {
            "& when not (@fullScreen)": {
              "padding-top": "(@paddingTop * 1rem)",
              "padding-bottom": "(@paddingBottom * 1rem)"
            },
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            ".row": {
              "justify-content": "center"
            },
            ".title-wrapper": {
              "margin-bottom": "60px",
              "@media (max-width: 992px)": {
                "margin-bottom": "30px"
              },
              ".mbr-section-title": {
                "margin-bottom": "40px",
                "@media (max-width: 992px)": {
                  "margin-bottom": "30px"
                }
              },
              ".text-wrapper": {
                ".mbr-text": {
                  "display": "inline-block",
                  "width": "35%",
                  "margin-bottom": "0",
                  "@media (max-width: 992px)": {
                    "width": "100%"
                  }
                }
              }
            },
            ".items-wrapper": {
              "display": "grid",
              "grid-template-columns": "1fr 1fr 1fr",
              "gap": "48px",
              "@media (max-width: 1440px)": {
                "gap": "30px"
              },
              "@media (max-width: 1200px)": {
                "grid-template-columns": "1fr 1fr",
                "gap": "16px"
              },
              "@media (max-width: 768px)": {
                "display": "block"
              }
            },
            ".item": {
              "transform": "rotate(-3deg)",
              "@media (max-width: 1200px)": {
                "transform": "none"
              },
              "&:nth-child(2n)": {
                "transform": "translateY(5px) rotate(0)",
                "@media (max-width: 1200px)": {
                  "transform": "none"
                }
              },
              "&:nth-child(3n)": {
                "transform": "rotate(2.7deg)",
                "@media (max-width: 1200px)": {
                  "transform": "none"
                }
              },
              "@media (max-width: 768px)": {
                "margin-bottom": "16px"
              },
              ".item-wrapper": {
                "height": "100%",
                "background-color": "@cardBg",
                "padding": "48px",
                "@media (max-width: 1440px)": {
                  "padding": "30px"
                },
                "@media (max-width: 1200px)": {
                  "padding": "30px 20px"
                },
                ".card-box": {
                  ".card-title": {
                    "margin-bottom": "60px",
                    "@media (max-width: 992px)": {
                      "margin-bottom": "30px"
                    }
                  },
                  ".iconfont-wrapper": {
                    "margin-bottom": "60px",
                    "@media (max-width: 992px)": {
                      "margin-bottom": "30px"
                    },
                    ".mbr-iconfont": {
                      "font-size": "230px",
                      "color": "@icon",
                      "@media (max-width: 1440px)": {
                        "font-size": "180px"
                      },
                      "@media (max-width: 1200px)": {
                        "font-size": "120px"
                      }
                    }
                  },
                  ".card-text": {
                    "margin-bottom": "0"
                  },
                  ".mbr-section-btn": {
                    "margin-top": "40px",
                    "width": "100%",
                    "@media (max-width: 992px)": {
                      "margin-top": "30px"
                    },
                    ".btn": {
                      "width": "100%",
                      "margin-bottom": "0"
                    }
                  }
                }
              }
            },
            ".mbr-section-title": {
              "color": "#ffffff"
            },
            ".mbr-text, .text-wrapper": {
              "color": "#ffffff"
            },
            ".card-title": {
              "color": "#000000"
            },
            ".card-text": {
              "color": "#000000"
            },
            ".iconfont-wrapper": {
              "text-align": "center"
            },
            ".card-title, .iconfont-wrapper": {
              "color": "#ffffff",
              "text-align": "center"
            },
            ".card-text, .mbr-section-btn": {
              "color": "#ffffff",
              "text-align": "center"
            }
          },
          "_cid": "uXbNTAlQmQ",
          "_anchor": "features01-ck",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "alias": false,
          "_styles": {
            "padding-top": "(@paddingTop * 15px)",
            "padding-bottom": "(@paddingBottom * 15px)",
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            ".mbr-subtitle": {
              "color": "#4f87fb",
              "font-weight": "800"
            },
            ".mbr-subtitle.display-4": {
              "font-size": "13px",
              "line-height": "1.85",
              "letter-spacing": "2px"
            },
            ".mbr-section-title": {
              "color": "#22a5e5",
              "font-weight": "700",
              "text-align": "center"
            },
            ".mbr-section-title.display-2": {
              "line-height": "1.2",
              "letter-spacing": "-0.5px"
            },
            ".mbr-section-text": {
              "line-height": "1.5",
              "margin-top": "10px",
              "color": "#6d7a8c"
            },
            ".timelines-container": {
              "margin-top": "60px",
              ".timeline-element": {
                "margin-bottom": "50px",
                "position": "relative",
                "word-wrap": "break-word",
                "word-break": "break-word",
                "display": "-webkit-flex",
                "-webkit-box-orient": "horizontal",
                "-webkit-box-direction": "normal",
                "flex-direction": "row",
                ".timeline-date-panel": {
                  ".time-line-date-content": {
                    ".mbr-figure": {
                      "img": {
                        "border-radius": "4px",
                        "box-shadow": "0 30px 50px rgba(0, 0, 0, 0.04)"
                      }
                    }
                  }
                },
                ".date": {
                  ".mbr-timeline-date": {
                    "color": "#130947",
                    "font-weight": "700"
                  },
                  ".display-7": {
                    "font-size": "20px",
                    "line-height": "1"
                  }
                },
                ".iconBackground": {
                  "position": "absolute",
                  "left": "41%",
                  "width": "12px",
                  "height": "12px",
                  "line-height": "1",
                  "text-align": "center",
                  "border-radius": "50%",
                  "background-color": "@timelineDotColor",
                  "font-size": "30px",
                  "display": "inline-block",
                  "top": "0px",
                  "margin-left": "-5px"
                },
                ".timeline-text-content": {
                  "margin-left": "2rem",
                  "text-align": "left",
                  ".mbr-timeline-title": {
                    "font-weight": "700",
                    "margin-bottom": "15px",
                    "color": "#130947"
                  },
                  ".mbr-timeline-text": {
                    "margin": "0 0 25px",
                    "line-height": "1.5",
                    "color": "#6d7a8c",
                    "font-weight": "400"
                  },
                  ".display-5": {
                    "line-height": "1.09",
                    "font-size": "22px",
                    "letter-spacing": "-0.5px"
                  },
                  ".display-7": {
                    "font-size": "16px",
                    "line-height": "1.5"
                  }
                }
              }
            },
            ".container-fluid": {
              "padding": "0 2rem"
            },
            ".separline:before, .first-separline:before": {
              "top": "0rem",
              "bottom": "0",
              "position": "absolute",
              "content": "''",
              "width": "4px",
              "background-color": "@timelineColor",
              "left": "calc(41% ~'-' 1px)",
              "height": "calc(100% ~'+' 3rem)"
            },
            ".separline:after": {
              "top": "calc(100% ~'+' 3.1rem)",
              "bottom": "0",
              "position": "absolute",
              "content": "''",
              "width": "4px",
              "background-color": "@timelineColor",
              "left": "calc(41% ~'-' 1px)",
              "height": "100%"
            },
            "@media (max-width: 768px)": {
              ".container-fluid": {
                "padding": "0 1rem"
              },
              ".iconBackground": {
                "left": "-9px !important",
                "top": "33px"
              },
              ".separline:before, .first-separline:before": {
                "left": "-10px !important"
              },
              ".separline:after": {
                "left": "-10px !important",
                "top": "calc(100% + 2.4rem)"
              },
              ".timeline-text-content": {
                "margin-left": "0 !important"
              },
              ".time-line-date-content": {
                "margin-right": "0 !important",
                "p": {
                  "float": "left !important"
                }
              },
              ".mbr-timeline-date": {
                "padding-bottom": "0 !important"
              },
              ".timelines-container .timeline-element .date .mbr-timeline-date": {
                "text-align": "left",
                "margin-top": "30px",
                "margin-bottom": "30px"
              }
            },
            ".reverseTimeline": {
              "display": "flex",
              "-webkit-box-orient": "vertical",
              "-webkit-box-direction": "reverse",
              "flex-direction": "column-reverse"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            ".timelines-container .timeline-element .timeline-text-content .mbr-timeline-text": {
              "color": "#ffffff"
            },
            ".timelines-container .timeline-element .timeline-text-content .mbr-timeline-title": {
              "color": "#ffffff"
            }
          },
          "_name": "timeline1",
          "_sourceTheme": "medicalm4",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"timeline1 medicalm4_timeline1\" group=\"Timelines\" data-bg-video=\"{{bg.type == 'video' && bg.value.url}}\" mbr-class=\"{'mbr-parallax-background': bg.parallax}\">\n\n    <mbr-parameters>\n        \n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"8\" step=\"1\" value=\"1\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"8\" step=\"1\" value=\"1\">\n        <select title=\"Timelines count\" name=\"timelinesAmount\">\n            <option value=\"1\">1</option>\n            <option value=\"2\" selected>2</option>\n            <option value=\"3\">3</option>\n            <option value=\"4\">4</option>\n            <option value=\"5\">5</option>\n            <option value=\"6\">6</option>\n            <option value=\"7\">7</option>\n            <option value=\"8\">8</option>\n            <option value=\"9\">9</option>\n            <option value=\"10\">10</option>\n            <option value=\"11\">11</option>\n            <option value=\"12\">12</option>\n        </select>\n        <input type=\"checkbox\" title=\"Reverse Timeline\" name=\"reverseTimeline\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Show Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Show Subtitle\" name=\"showSubtitle\">\n        <input type=\"checkbox\" title=\"Show Text\" name=\"showText\">\n        <input type=\"checkbox\" title=\"Dates\" name=\"showDates\">\n        <input type=\"checkbox\" title=\"Images\" name=\"showImages\" checked>\n        <input type=\"checkbox\" title=\"Timeline Titles\" name=\"showTimelineTitles\" checked>\n        <input type=\"checkbox\" title=\"Timeline Text\" name=\"showTimelineText\" checked>\n        <input type=\"checkbox\" title=\"Images\" name=\"showImages\" checked>\n        <header>Colors</header>\n        <input type=\"color\" title=\"Timelines\" name=\"timelineColor\" value=\"#ffffff\">\n        <input type=\"color\" title=\"Timeline Dot Color\" name=\"timelineDotColor\" value=\"#4f87fb\">\n\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" value=\"@ADDONS_PATH@/medicalm4/components/_images/background1.jpg\" title=\"Image\">\n            <input type=\"color\" value=\"#000000\" title=\"Color\" selected>\n            <input type=\"video\" value=\"https://www.youtube.com/watch?v=9morbKMwCu4\" title=\"Video\">\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"@ADDONS_PATH@/medicalm4/components/_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\n        <input type=\"color\" title=\"Color\" name=\"overlayColor\" value=\"#232323\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.8\" condition=\"overlay && bg.type !== 'color'\">\n        \n    </mbr-parameters>\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n\n\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type!== 'color'\" mbr-style=\"{'opacity': overlayOpacity, 'background-color': overlayColor}\">\n    </div>\n\n    <div class=\"container align-center\">\n        <h3 class=\"mbr-subtitle mbr-fonts-style mbr-bold\" data-app-selector=\".mbr-subtitle\" mbr-if=\"showSubtitle\" mbr-theme-style=\"display-4\">WHO WE ARE</h3>\n        <h1 class=\"mbr-section-title mbr-fonts-style mbr-bold\" data-app-selector=\".mbr-section-title\" mbr-if=\"showTitle\" mbr-theme-style=\"display-5\">Upskill your trading and investing<br>with state-of-the-art tools, strategy and expert instructors</h1>\n        <h2 class=\"mbr-section-text mbr-fonts-style mbr-light\" data-app-selector=\".mbr-section-text\" mbr-if=\"showText\" mbr-theme-style=\"display-7\">Lorem ipsum dolor sit amet, consectetur adipiscing elit. Quisque a nisi\n            faucibus,\n            blandit nisl quis, ornare mauris. Quisque facilisis gravida velit, quis tempus eros. Aenean quis nisi\n            consequat, elementum erat id, ultricies risus.</h2>\n\n        <div class=\"timelines-container\" mbri-timelines mbr-class=\"{'pt-4':!showSubtitle, 'reverseTimeline' : reverseTimeline}\">\n            \n            <div class=\"row timeline-element first-separline\" mbr-class=\"{'separline': !reverseTimeline &amp;&amp; timelinesAmount > 1}\">\n                <div class=\"timeline-date-panel col-xs-12 col-md-3 align-left\">\n                    <div class=\"time-line-date-content\">\n                        <div class=\"mbr-figure\" mbr-if=\"showImages\">\n                            <img src=\"@PROJECT_PATH@/assets/images/95-of-beginner-traders-lose-heres-the-free-playbook-that-can-save-you-506x899.jpeg\" alt=\"Mobirise\" title>\n                        </div>\n\n                    </div>\n                </div>\n                <div class=\"date col-xs-12 col-md-2\">\n                    <p class=\"mbr-timeline-date mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showDates\" data-app-selector=\".timelines-container .timeline-element .date .mbr-timeline-date\">\n                        2020\n                    </p>\n                </div>\n                <span class=\"iconBackground\"></span>\n                <div class=\"col-xs-12 col-md-7\">\n                    <div class=\"timeline-text-content\">\n                        <h4 class=\"mbr-timeline-title mbr-fonts-style\" mbr-theme-style=\"display-5\" data-app-selector=\".timelines-container .timeline-element .timeline-text-content .mbr-timeline-title\" mbr-if=\"showTimelineTitles\">Journey from Beginner&nbsp;</h4>\n\n                        <p class=\"mbr-timeline-text mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".timelines-container .timeline-element .timeline-text-content .mbr-timeline-text\" mbr-if=\"showTimelineText\">\n                            \"Start your trading journey with Finbytech. Learn the basics of the stock market in simple, easy-to-follow steps. Gain confidence through structured lessons, practical insights, and guided practice. Build a strong foundation and take your first step toward financial independence with our beginner-friendly training.\"\n                        </p>\n                    </div>\n                </div>\n            </div>\n            \n            <div class=\"row timeline-element \" mbr-if=\"timelinesAmount > 1\" mbr-class=\"{'separline':timelinesAmount>2 &amp;&amp; !reverseTimeline || !reverseTimeline &amp;&amp; timelinesAmount > 2 || reverseTimeline &amp;&amp; timelinesAmount > 1}\">\n                <div class=\"timeline-date-panel col-xs-12 col-md-3 align-left\">\n                    <div class=\"time-line-date-content\">\n                        <div class=\"mbr-figure\" mbr-if=\"showImages\">\n                            <img src=\"@PROJECT_PATH@/assets/images/what-is-trading-506x902.jpeg\" alt=\"Mobirise\" title>\n                        </div>\n                    </div>\n                </div>\n                <div class=\"date col-xs-12 col-md-2\">\n                    <p class=\"mbr-timeline-date mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showDates\" data-app-selector=\".timelines-container .timeline-element .date .mbr-timeline-date\">\n                        2021\n                    </p>\n                </div>\n                <span class=\"iconBackground\"></span>\n                <div class=\"col-xs-12 col-md-7\">\n                    <div class=\"timeline-text-content\">\n                        <h4 class=\"mbr-timeline-title mbr-fonts-style\" mbr-theme-style=\"display-5\" data-app-selector=\".timelines-container .timeline-element .timeline-text-content .mbr-timeline-title\" mbr-if=\"showTimelineTitles\">\n                            Advanced in market analysis in every aspect&nbsp; &nbsp;</h4>\n                        <p class=\"mbr-timeline-text mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".timelines-container .timeline-element .timeline-text-content .mbr-timeline-text\" mbr-if=\"showTimelineText\">\"Take your trading skills to the next level with Finbytech. Master advanced strategies, in-depth market analysis, and risk management techniques. Learn to identify opportunities, trade with precision, and sharpen your decision-making. Designed for experienced traders, our advanced training helps you achieve consistent profits and financial growth.\"<br><br>✅ Unmatched Reputation&nbsp;<br>✅ Comprehensive Skill building\n<br>✅ Proprietary State-of-the-art-tools\n<br>✅ Exceptional Education\n<br>&nbsp;<br></p>\n                    </div>\n                </div>\n            </div>\n            \n            <div class=\"row timeline-element\" mbr-if=\"timelinesAmount > 2\" mbr-class=\"{'separline': !reverseTimeline &amp;&amp; timelinesAmount > 3 || reverseTimeline &amp;&amp; timelinesAmount > 2}\">\n                <div class=\"timeline-date-panel col-xs-12 col-md-3 align-left\">\n                    <div class=\"time-line-date-content\">\n                        <div class=\"mbr-figure\" mbr-if=\"showImages\">\n                            <img src=\"@ADDONS_PATH@/medicalm4/components/_images/img/03.jpg\" alt=\"Mobirise\" title>\n                        </div>\n                    </div>\n                </div>\n                <div class=\"date col-xs-12 col-md-2\">\n                    <p class=\"mbr-timeline-date mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showDates\" data-app-selector=\".timelines-container .timeline-element .date .mbr-timeline-date\">\n                        2022\n                    </p>\n                </div>\n                <span class=\"iconBackground\"></span>\n                <div class=\"col-xs-12 col-md-7\">\n                    <div class=\"timeline-text-content\">\n                        <h4 class=\"mbr-timeline-title mbr-fonts-style\" mbr-theme-style=\"display-5\" data-app-selector=\".timelines-container .timeline-element .timeline-text-content .mbr-timeline-title\" mbr-if=\"showTimelineTitles\">\n                            Opening of the US Institute of Primary Care\n                        </h4>\n                        <p class=\"mbr-timeline-text mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".timelines-container .timeline-element .timeline-text-content .mbr-timeline-text\" mbr-if=\"showTimelineText\">\n                            Lorem ipsum dolor sit amet, consectetur adipiscing elit. Nam erat libero, bibendum in libero\n                            tempor, luctus volutpat ligula.\n                            Integer fringilla porttitor pretium. Nam erat felis, iaculis id justo ut, ullamcorper\n                            feugiat\n                            elit. Proin vel lectus auctor, porttitor ligula vitae, convallis leo. In eget massa elit.\n                        </p>\n                    </div>\n                </div>\n            </div>\n            \n            <div class=\"row timeline-element \" mbr-if=\"timelinesAmount > 3\" mbr-class=\"{'separline': !reverseTimeline &amp;&amp; timelinesAmount > 4 || reverseTimeline &amp;&amp; timelinesAmount > 3}\">\n                <div class=\"timeline-date-panel col-xs-12 col-md-3 align-left\">\n                    <div class=\"time-line-date-content\">\n                        <div class=\"mbr-figure\" mbr-if=\"showImages\">\n                            <img src=\"@ADDONS_PATH@/medicalm4/components/_images/img/04.jpg\" alt=\"Mobirise\" title>\n                        </div>\n                    </div>\n                </div>\n                <div class=\"date col-xs-12 col-md-2\">\n                    <p class=\"mbr-timeline-date mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showDates\" data-app-selector=\".timelines-container .timeline-element .date .mbr-timeline-date\">\n                        2023\n                    </p>\n                </div>\n                <span class=\"iconBackground\"></span>\n                <div class=\"col-xs-12 col-md-7\">\n                    <div class=\"timeline-text-content\">\n                        <h4 class=\"mbr-timeline-title mbr-fonts-style\" mbr-theme-style=\"display-5\" data-app-selector=\".timelines-container .timeline-element .timeline-text-content .mbr-timeline-title\" mbr-if=\"showTimelineTitles\">\n                            150 years of the Department of Surgey\n                        </h4>\n                        <p class=\"mbr-timeline-text mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".timelines-container .timeline-element .timeline-text-content .mbr-timeline-text\" mbr-if=\"showTimelineText\">\n                            Lorem ipsum dolor sit amet, consectetur adipiscing elit. Nam erat libero, bibendum in libero\n                            tempor, luctus volutpat ligula.\n                            Integer fringilla porttitor pretium. Nam erat felis, iaculis id justo ut, ullamcorper\n                            feugiat\n                            elit. Proin vel lectus auctor, porttitor ligula vitae, convallis leo. In eget massa elit.\n                        </p>\n                    </div>\n                </div>\n            </div>\n            \n            <div class=\"row timeline-element\" mbr-if=\"timelinesAmount > 4\" mbr-class=\"{'separline': !reverseTimeline &amp;&amp; timelinesAmount > 5 || reverseTimeline &amp;&amp; timelinesAmount > 4}\">\n                <div class=\"timeline-date-panel col-xs-12 col-md-3 align-left\">\n                    <div class=\"time-line-date-content\">\n                        <div class=\"mbr-figure\" mbr-if=\"showImages\">\n                            <img src=\"@ADDONS_PATH@/medicalm4/components/_images/img/05.jpg\" alt=\"Mobirise\" title>\n                        </div>\n                    </div>\n                </div>\n                <div class=\"date col-xs-12 col-md-2\">\n                    <p class=\"mbr-timeline-date mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showDates\" data-app-selector=\".timelines-container .timeline-element .date .mbr-timeline-date\">\n                        2024\n                    </p>\n                </div>\n                <span class=\"iconBackground\"></span>\n                <div class=\"col-xs-12 col-md-7\">\n                    <div class=\"timeline-text-content\">\n                        <h4 class=\"mbr-timeline-title mbr-fonts-style\" mbr-theme-style=\"display-5\" data-app-selector=\".timelines-container .timeline-element .timeline-text-content .mbr-timeline-title\" mbr-if=\"showTimelineTitles\">\n                            Сopywriting\n                        </h4>\n                        <p class=\"mbr-timeline-text mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".timelines-container .timeline-element .timeline-text-content .mbr-timeline-text\" mbr-if=\"showTimelineText\">\n                            Lorem ipsum dolor sit amet, consectetur adipiscing elit. Nam erat libero, bibendum in libero\n                            tempor, luctus volutpat ligula.\n                            Integer fringilla porttitor pretium. Nam erat felis, iaculis id justo ut, ullamcorper\n                            feugiat\n                            elit. Proin vel lectus auctor, porttitor ligula vitae, convallis leo. In eget massa elit.\n                        </p>\n                    </div>\n                </div>\n            </div>\n            \n            <div class=\"row timeline-element\" mbr-if=\"timelinesAmount > 5\" mbr-class=\"{'separline': !reverseTimeline &amp