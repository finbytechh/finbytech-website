            ".mbr-section-btn": {
              "margin-top": "40px"
            },
            ".lines-container": {
              "width": "100%",
              "& when (@reverseContent)": {
                "padding-right": "10%"
              },
              "& when not (@reverseContent)": {
                "padding-left": "10%"
              },
              "@media (max-width: 991px)": {
                "padding": "0",
                "margin-top": "40px"
              }
            },
            ".lines-title": {
              "color": "#C4CFDE",
              "margin-bottom": "34px"
            },
            ".lines-wrap": {
              "width": "100%"
            },
            ".line-item-container": {
              "width": "100%",
              "&:not(:first-child)": {
                "margin-top": "40px"
              }
            },
            ".line-text": {
              "color": "#C4CFDE",
              "opacity": "0.75",
              "margin-bottom": "10px"
            },
            ".line-item": {
              "width": "100%",
              "height": "60px",
              "padding": "5px",
              "background-color": "@linesBg",
              "border-radius": "500px",
              "overflow": "hidden",
              "box-shadow": "inset 8px 8px 16px rgba(0, 0, 0, 0.46), inset -8px -8px 16px rgba(56, 62, 69, 0.46)"
            },
            ".line-item-active": {
              "height": "100%",
              "border-radius": "500px",
              "transition": "width .6s ease",
              "background": "linear-gradient(145deg, @linesBg1 0%, @linesBg2 100%)"
            },
            ".line-item-active-1": {
              "width": "(@lineActive1 * 1%)"
            },
            ".line-item-active-2": {
              "width": "(@lineActive2 * 1%)"
            },
            ".line-item-active-3": {
              "width": "(@lineActive3 * 1%)"
            },
            ".mbr-section-subtitle, .mbr-section-btn": {
              "color": "#ffe885"
            }
          },
