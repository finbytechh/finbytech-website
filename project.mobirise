              "margin-left": "auto",
              "max-width": "70%",
              "border-radius": "1.7vw",
              "overflow": "hidden",
              "border": "1px solid @menuBorderColor",
              "& when not (@transparent)": {
                "background": "@menuBgColor"
              },
              "& when (@transparent)": {
