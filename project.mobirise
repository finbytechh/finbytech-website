                  "-webkit-text-stroke-color": "@descBorder",
                  "box-shadow": "4px 4px 0 0 @descBorder",
                  "border": "2px solid @descBorder",
                  "background-color": "@descBg",
                  "-webkit-text-stroke-width": ".15rem",
