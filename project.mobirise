          "_cid": "uXbQG8eCR7",
          "_anchor": "timeline1-cm",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "alias": false,
          "_styles": {
            "padding-top": "(@paddingTop * 1rem)",
            "padding-bottom": "(@paddingBottom * 1rem)",
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            ".wrapper": {
              "@media (max-width: 991px)": {
                "padding": "0"
              },
              "@media (min-width: 992px)": {
                "padding": "4rem 6rem"
              }
            },
            ".card-wrapper": {
              "background-color": "@cardsBg",
              "border-radius": "30px",
              "border": "1px solid",
              "background": "@cardsBg",
              "transition": "all 0.3s",
              "position": "relative",
              "padding": "44px 40px"
            },
            "@media (max-width: 991px)": {
              ".card-wrapper": {
                "padding": "2rem 1rem"
              }
            },
            ".btn": {
              "border-radius": "30px",
              "@media (max-width: 768px)": {
                "width": "100%",
                "margin-left": "0"
              }
            },
            ".b1": {
              "background-color": "#FFA29D"
            },
            ".b2": {
              "background-color": "#cacbcc"
            },
            ".b3": {
              "background-color": "#51add0"
            },
            ".info": {
              "width": "120px",
              "height": "120px",
              "position": "absolute",
              "top": "-40px",
              "right": "-40px",
              "@media (max-width: 768px)": {
                "right": "-10px"
              }
            },
            ".mbr-section-title": {
              "color": "#ffffff",
              "text-align": "center"
            },
            "P": {
              "color": "#ffffff"
            }
          },
          "_name": "content7",
          "_sourceTheme": "masterclassm5",
          "_customHTML": "<section data-bs-version=\"5.1\" group=\"Content\" class=\"content7\" data-bg-video=\"{{bg.type == 'video' && bg.value.url}}\" mbr-class=\"{\n    'mbr-fullscreen': fullScreen, 'mbr-parallax-background': bg.parallax}\">\n\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\" checked>\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"0\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"0\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <header>Cards</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitleCard\" checked>\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\" checked>\n        <input type=\"checkbox\" title=\"Buttons\" name=\"showButtons\" checked>\n        <input type=\"checkbox\" title=\"Info\" name=\"showInfo\">\n        <select title=\"Amount\" name=\"cardsAmount\">\n            <option value=\"1\">1</option>\n            <option value=\"2\" selected>2</option>\n            <option value=\"3\">3</option>\n            <option value=\"4\">4</option>\n            <option value=\"5\">5</option>\n            <option value=\"6\">6</option>\n        </select>\n        <input type=\"color\" title=\"Background\" name=\"cardsBg\" value=\"#0c86c1\">\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"@ADDONS_PATH@/masterclassm5/components/_images/background3.jpg\" parallax>\n            <input type=\"color\" title=\"Color\" value=\"#000000\" selected>\n        </fieldset>\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\">\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#ffffff\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.5\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type!== 'color'\" mbr-style=\"{'opacity': overlayOpacity, 'background-color': overlayColor}\">\n    </div>\n\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"wrapper\">\n            <div class=\"mbr-section-head\" mbr-if=\"showTitle\">\n                <h3 mbr-if=\"showTitle\" class=\"mbr-section-title mbr-fonts-style mb-0\" data-app-selector=\".mbr-section-title\" mbr-theme-style=\"display-5\"><b>Flagship Programs ( 60days Course)</b></h3>\n            </div>\n            <div class=\"row mt-4\">\n                <div class=\"card col-12\">\n                    <div class=\"card-wrapper mb-5\">\n                        <div mbr-if=\"showInfo\">\n                            <div class=\"info b3 rounded-circle text-center text-white  d-flex align-items-center\">\n                                <h5 class=\"mbr-text mbr-fonts-style m-auto p-2\" mbr-theme-style=\"display-4\">12 September\n                                </h5>\n                            </div>\n                        </div>\n\n                        <div class=\"top-line mb-4\" mbr-if=\"showTitleCard\">\n                            <h4 class=\"card-title mbr-fonts-style\" mbr-theme-style=\"display-5\" data-app-selector=\".card-title\"><b>ValueVision: Mastering Fundamental Analysis</b></h4>\n                        </div>\n                        <div class=\"bottom-line row\">\n                            <div class=\"col-12 col-lg-5 mb-5 mb-lg-0\">\n                                <p class=\"mbr-text mbr-fonts-style m-0\" mbr-theme-style=\"display-7\" mbr-if=\"showText\">Master the art of finding true value in stocks – from analyzing financial statements to valuing companies and building wealth. Learn Fundamental Analysis step by step with Finbytech.<br><br><b>here what you will learn in this course :&nbsp;</b><br></p>\n                            </div>\n                            <div class=\"col-12 col-lg-7\">\n                                <div mbr-buttons mbr-theme-style=\"display-4\" class=\"mbr-section-btn text-center\" mbr-if=\"showButtons\"><a class=\"btn btn-primary\" href=\"/\" data-app-placeholder=\"Type Text\">📌 Basics of Fundamental Analysis</a>\n                                    <a class=\"btn btn-primary\" href=\"/\" data-app-placeholder=\"Type Text\">📌 Macroeconomic Analysis</a>\n                                    <a class=\"btn btn-primary\" href=\"/\" data-app-placeholder=\"Type Text\">📌 Industry &amp; Sector Analysis</a> <a class=\"btn btn-primary\" href=\"/\" data-app-placeholder=\"Type Text\">📌 Company Financial Statements</a> <a class=\"btn btn-primary\" href=\"/\" data-app-placeholder=\"Type Text\">📌 Key Ratios &amp; Metrics</a> <a class=\"btn btn-primary\" href=\"/\" data-app-placeholder=\"Type Text\">📌 Valuation Methods</a> <a class=\"btn btn-primary\" href=\"/\" data-app-placeholder=\"Type Text\">📌 Qualitative Analysis</a> <a class=\"btn btn-primary\" href=\"/\" data-app-placeholder=\"Type Text\">📌 Advanced Concepts</a> <a class=\"btn btn-primary\" href=\"/\" data-app-placeholder=\"Type Text\">📌 Application in Investing</a></div>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n                <div class=\"card col-12\" mbr-if=\"cardsAmount>1\">\n                    <div class=\"card-wrapper mb-5\">\n                        <div mbr-if=\"showInfo\">\n                            <div class=\"info b1 rounded-circle text-center text-white  d-flex align-items-center\">\n                                <h5 class=\"mbr-text mbr-fonts-style m-auto p-2\" mbr-theme-style=\"display-4\">Candle to Capital: Mastering Technical Charts</h5>\n                            </div>\n                        </div>\n\n                        <div class=\"top-line mb-4\" mbr-if=\"showTitleCard\">\n                            <h4 class=\"card-title mbr-fonts-style\" mbr-theme-style=\"display-5\" data-app-selector=\".card-title\"><b>Candle to Capital: Mastering Technical Charts</b></h4>\n                        </div>\n                        <div class=\"bottom-line row\">\n                            <div class=\"col-12 col-lg-5 mb-5 mb-lg-0\">\n                                <p class=\"mbr-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showText\">From the first candlestick to consistent accuracy – unlock the power of charts and transform candles into capital with Finbytech. <br><br><b>here what you will learn in this course :&nbsp;</b></p>\n                            </div>\n                            <div class=\"col-12 col-lg-7\">\n                                <div mbr-buttons mbr-theme-style=\"display-4\" class=\"mbr-section-btn text-center\" mbr-if=\"showButtons\"><a class=\"btn btn-warning\" href=\"/\" data-app-placeholder=\"Type Text\">📌 Basics of Technical Analysis</a>\n                                    <a class=\"btn btn-warning\" href=\"/\" data-app-placeholder=\"Type Text\">📌 Chart Patterns</a>\n                                    <a class=\"btn btn-warning\" href=\"/\" data-app-placeholder=\"Type Text\">📌 Candlestick Patterns</a> <a class=\"btn btn-warning\" href=\"/\" data-app-placeholder=\"Type Text\">📌 Indicators &amp; Oscillators</a> <a class=\"btn btn-warning\" href=\"/\" data-app-placeholder=\"Type Text\">📌 Advanced Concepts</a> <a class=\"btn btn-warning\" href=\"/\" data-app-placeholder=\"Type Text\">📌 Risk Management &amp; Psychology</a> <a class=\"btn btn-warning\" href=\"/\" data-app-placeholder=\"Type Text\">📌 More</a></div>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n                <div class=\"card col-12\" mbr-if=\"cardsAmount>2\">\n                    <div class=\"card-wrapper mb-5\">\n                        <div mbr-if=\"showInfo\">\n                            <div class=\"info b2 rounded-circle text-center text-white  d-flex align-items-center\">\n                                <h5 class=\"mbr-text mbr-fonts-style m-auto p-2\" mbr-theme-style=\"display-4\">soon</h5>\n                            </div>\n                        </div>\n\n                        <div class=\"top-line mb-4\" mbr-if=\"showTitleCard\">\n                            <h4 class=\"card-title mbr-fonts-style\" mbr-theme-style=\"display-5\" data-app-selector=\".card-title\">Faculty\n                                web design</h4>\n                        </div>\n                        <div class=\"bottom-line row\">\n                            <div class=\"col-12 col-lg-5 mb-5 mb-lg-0\">\n                                <p class=\"mbr-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showText\">\n                                    Tools to help web designers create cool websites that help businesses\n                                </p>\n                            </div>\n                            <div class=\"col-12 col-lg-7\">\n                                <div mbr-buttons mbr-theme-style=\"display-4\" class=\"mbr-section-btn text-white text-center\" mbr-if=\"showButtons\">\n                                    <a class=\"btn btn-secondary\" href=\"/\" data-app-placeholder=\"Type Text\">Available</a>\n                                    <a class=\"btn btn-secondary\" href=\"/\" data-app-placeholder=\"Type Text\">6\n                                        lessons</a>\n                                    <a class=\"btn btn-secondary\" href=\"/\" data-app-placeholder=\"Type Text\">Online\n                                        learning</a></div>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n                <div class=\"card col-12\" mbr-if=\"cardsAmount>3\">\n                    <div class=\"card-wrapper mb-5\">\n                        <div mbr-if=\"showInfo\">\n                            <div class=\"info b1 rounded-circle text-center text-white  d-flex align-items-center\">\n                                <h5 class=\"mbr-text mbr-fonts-style m-auto p-2\" mbr-theme-style=\"display-4\">every Friday\n                                </h5>\n                            </div>\n                        </div>\n\n                        <div class=\"top-line mb-4\" mbr-if=\"showTitleCard\">\n                            <h4 class=\"card-title mbr-fonts-style\" mbr-theme-style=\"display-5\" data-app-selector=\".card-title\">Faculty\n                                web design</h4>\n                        </div>\n                        <div class=\"bottom-line row\">\n                            <div class=\"col-12 col-lg-5 mb-5 mb-lg-0\">\n                                <p class=\"mbr-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showText\">\n                                    Tools to help web designers create cool websites that help businesses\n                                </p>\n                            </div>\n                            <div class=\"col-12 col-lg-7\">\n                                <div mbr-buttons mbr-theme-style=\"display-4\" class=\"mbr-section-btn text-center\" mbr-if=\"showButtons\">\n                                    <a class=\"btn btn-warning\" href=\"/\" data-app-placeholder=\"Type Text\">Available</a>\n                                    <a class=\"btn btn-warning\" href=\"/\" data-app-placeholder=\"Type Text\">6\n                                        lessons</a>\n                                    <a class=\"btn btn-warning\" href=\"/\" data-app-placeholder=\"Type Text\">Online\n                                        learning</a></div>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n                <div class=\"card col-12\" mbr-if=\"cardsAmount>4\">\n                    <div class=\"card-wrapper mb-5\">\n                        <div mbr-if=\"showInfo\">\n                            <div class=\"info b2 rounded-circle text-center text-white  d-flex align-items-center\">\n                                <h5 class=\"mbr-text mbr-fonts-style m-auto p-2\" mbr-theme-style=\"display-4\">soon</h5>\n                            </div>\n                        </div>\n\n                        <div class=\"top-line mb-3\" mbr-if=\"showTitleCard\">\n                            <h4 class=\"card-title mbr-fonts-style\" mbr-theme-style=\"display-5\" data-app-selector=\".card-title\">Faculty\n                                web design</h4>\n                        </div>\n                        <div class=\"bottom-line row\">\n                            <div class=\"col-12 col-lg-5 mb-5 mb-lg-0\">\n                                <p class=\"mbr-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showText\">\n                                    Tools to help web designers create cool websites that help businesses\n                                </p>\n                            </div>\n                            <div class=\"col-12 col-lg-7\">\n                                <div mbr-buttons mbr-theme-style=\"display-4\" class=\"mbr-section-btn text-white text-center\" mbr-if=\"showButtons\"><a class=\"btn btn-secondary\" href=\"/\" data-app-placeholder=\"Type Text\">Available</a>\n                                    <a class=\"btn btn-secondary\" href=\"/\" data-app-placeholder=\"Type Text\">6\n                                        lessons</a>\n                                    <a class=\"btn btn-secondary\" href=\"/\" data-app-placeholder=\"Type Text\">Online\n                                        learning</a></div>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n                <div class=\"card col-12\" mbr-if=\"cardsAmount>5\">\n                    <div class=\"card-wrapper\">\n                        <div mbr-if=\"showInfo\">\n                            <div class=\"info b2 rounded-circle text-center text-white  d-flex align-items-center\">\n                                <h5 class=\"mbr-text mbr-fonts-style m-auto p-2\" mbr-theme-style=\"display-4\">soon</h5>\n                            </div>\n                        </div>\n\n                        <div class=\"top-line mb-3\" mbr-if=\"showTitleCard\">\n                            <h4 class=\"card-title mbr-fonts-style\" mbr-theme-style=\"display-5\" data-app-selector=\".card-title\">Faculty\n                                web design</h4>\n                        </div>\n                        <div class=\"bottom-line row\">\n                            <div class=\"col-12 col-lg-5 mb-5 mb-lg-0\">\n                                <p class=\"mbr-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showText\">\n                                    Tools to help web designers create cool websites that help businesses\n                                </p>\n                            </div>\n                            <div class=\"col-12 col-lg-7\">\n                                <div mbr-buttons mbr-theme-style=\"display-4\" class=\"mbr-section-btn text-white text-center\" mbr-if=\"showButtons\">\n                                    <a class=\"btn btn-secondary\" href=\"/\" data-app-placeholder=\"Type Text\">Available</a>\n                                    <a class=\"btn btn-secondary\" href=\"/\" data-app-placeholder=\"Type Text\">6\n                                        lessons</a>\n                                    <a class=\"btn btn-secondary\" href=\"/\" data-app-placeholder=\"Type Text\">Online\n                                        learning</a></div>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_cid": "uXbXlQUjHq",
          "_anchor": "content7-cn",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "alias": false,
          "_styles": {
            "padding-top": "(@paddingTop * 1rem)",
            "padding-bottom": "(@paddingBottom * 1rem)",
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            ".nav-tabs .nav-item.open .nav-link:focus, .nav-tabs .nav-link.active:focus": {
              "outline": "none"
            },
            ".nav-tabs": {
              "flex-wrap": "wrap",
              "border-bottom": "1px solid @activeColor"
            },
            ".nav-item": {
              "@media (max-width: 767px)": {
                "width": "100%",
                "margin": "0"
              }
            },
            ".nav-tabs .nav-link": {
              "transition": "all .5s",
              "border": "none",
              "border-bottom": "3px solid transparent",
              "border-radius": "0 !important",
              "&:not(.active)": {
                "color": "@tabsColor"
              }
            },
            ".nav-tabs .nav-item": {
              "margin-right": "1.5rem"
            },
            ".nav-link, .nav-link.active": {
              "padding": "1rem 0",
              "background-color": "transparent"
            },
            ".nav-tabs .nav-link.active": {
              "color": "@activeColor",
              "border-bottom": "3px solid @activeColor"
            },
            "H4": {
              "text-align": "center"
            },
            "H3": {
              "text-align": "center",
              "color": "#ffffff"
            },
            "P": {
              "color": "#ffffff",
              "text-align": "left"
            }
          },
          "_name": "tabs1",
          "_sourceTheme": "mobirise5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"tabs content18\" group=\"Content\" data-bg-video=\"{{bg.type == 'video'&&bg.value.url}}\" mbr-class=\"{'mbr-parallax-background':bg.parallax}\" plugins=\"mbr-tabs\">\n\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" name=\"fullWidth\" title=\"Full Width\">\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"2\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"2\">\n        <input type=\"range\" name=\"textWidth\" title=\"Width\" min=\"4\" max=\"12\" value=\"12\" step=\"1\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Subtitle\" name=\"showSubtitle\">\n        <header>Tabs</header>\n        <select title=\"Count\" name=\"bootstrapTabs\">\n            <option value=\"1\">1</option>\n            <option value=\"2\">2</option>\n            <option value=\"3\" selected>3</option>\n            <option value=\"4\">4</option>\n            <option value=\"5\">5</option>\n            <option value=\"6\">6</option>\n        </select>\n        <input type=\"color\" name=\"tabsColor\" title=\"Color\" value=\"#e6c63b\">\n        <input type=\"color\" name=\"activeColor\" title=\"Active Color\" value=\"#22a5e5\">\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"../_images/background1.jpg\">\n            <input type=\"color\" title=\"Color\" value=\"#000000\" selected>\n            <input type=\"video\" title=\"Video\" value=\"https://vimeo.com/428046504\">\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"../_images/background13.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#ffffff\" condition=\"overlay&&bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.7\" condition=\"overlay&&bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay&&bg.type!== 'color'\" mbr-style=\"{'opacity': overlayOpacity, 'background-color': overlayColor}\">\n    </div>\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row justify-content-center\" mbr-if=\"showTitle || showSubtitle\">\n            <div class=\"col-12 col-md-{{textWidth}}\">\n                <h3 class=\"mbr-section-title mb-0 mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showTitle\"><b>Premium 3-Module Program Structure covering Stocks, Equity, Futures, Options &amp; MCX</b></h3>\n                <h4 class=\"mbr-section-subtitle mb-0 mt-2 mbr-fonts-style\" mbr-theme-style=\"display-5\" mbr-if=\"showSubtitle\">Tabs Subtitle</h4>\n            </div>\n        </div>\n        <div class=\"row justify-content-center mt-4\">\n            <div class=\"col-12 col-md-{{textWidth}}\">\n                <ul class=\"nav nav-tabs mb-4\" role=\"tablist\">\n                    <li mbr-buttons mbr-theme-style=\"display-4\" class=\"nav-item first mbr-fonts-style\" data-toolbar=\"-mbrBtnAdd,-mbrBtnMove,-mbrLink,-mbrBtnRemove,-iconFont\"><a class=\"nav-link mbr-fonts-style show active\" role=\"tab\" data-toggle=\"tab\" data-bs-toggle=\"tab\" href=\"#tabs1-ct_tab0\" data-app-placeholder=\"Type Text\" aria-selected=\"true\">📘 Module 1: Market Foundations (Beginner Level)</a></li>\n                    <li mbr-buttons mbr-theme-style=\"display-4\" class=\"nav-item\" mbr-if=\"bootstrapTabs > 1\" data-toolbar=\"-mbrBtnAdd,-mbrBtnMove,-mbrLink,-mbrBtnRemove,-iconFont\"><a class=\"nav-link mbr-fonts-style\" role=\"tab\" data-toggle=\"tab\" data-bs-toggle=\"tab\" href=\"#tabs1-ct_tab1\" data-app-placeholder=\"Type Text\" aria-selected=\"false\">📗 Module 2: Trading &amp; Investing Strategies (Intermediate Level)</a></li>\n                    <li mbr-buttons mbr-theme-style=\"display-4\" class=\"nav-item\" mbr-if=\"bootstrapTabs > 2\" data-toolbar=\"-mbrBtnAdd,-mbrBtnMove,-mbrLink,-mbrBtnRemove,-iconFont\"><a class=\"nav-link mbr-fonts-style active\" role=\"tab\" data-toggle=\"tab\" data-bs-toggle=\"tab\" href=\"#tabs1-ct_tab2\" data-app-placeholder=\"Type Text\" aria-selected=\"true\">📙 Module 3: Professional Mastery (Advanced Level)</a></li>\n                    <li mbr-buttons mbr-theme-style=\"display-7\" class=\"nav-item\" mbr-if=\"bootstrapTabs > 3\" data-toolbar=\"-mbrBtnAdd,-mbrBtnMove,-mbrLink,-mbrBtnRemove,-iconFont\"><a class=\"nav-link mbr-fonts-style\" role=\"tab\" data-toggle=\"tab\" data-bs-toggle=\"tab\" href=\"#tabs1-ct_tab3\" data-app-placeholder=\"Type Text\" aria-selected=\"false\">📕 Module 4: Advanced Options Trading</a></li>\n                    <li mbr-buttons mbr-theme-style=\"display-7\" class=\"nav-item\" mbr-if=\"bootstrapTabs > 4\" data-toolbar=\"-mbrBtnAdd,-mbrBtnMove,-mbrLink,-mbrBtnRemove,-iconFont\"><a class=\"nav-link mbr-fonts-style\" role=\"tab\" data-toggle=\"tab\" data-bs-toggle=\"tab\" href=\"#tabs1-ct_tab4\" data-app-placeholder=\"Type Text\" aria-selected=\"false\">📗 Module 5: Advanced Commodity (MCX) Trading</a></li>\n                    <li mbr-buttons mbr-theme-style=\"display-7\" class=\"nav-item\" mbr-if=\"bootstrapTabs > 5\" data-toolbar=\"-mbrBtnAdd,-mbrBtnMove,-mbrLink,-mbrBtnRemove,-iconFont\"><a class=\"nav-link mbr-fonts-style active\" role=\"tab\" data-toggle=\"tab\" data-bs-toggle=\"tab\" href=\"#tabs1-ct_tab5\" data-app-placeholder=\"Type Text\" aria-selected=\"true\">📙 Module 6: Quantitative &amp; Algorithmic Trading Basics</a></li>\n                </ul>\n                <div class=\"tab-content\">\n                    <div id=\"tab1\" class=\"tab-pane in active\" role=\"tabpanel\">\n                        <div class=\"row\">\n                            <div class=\"col-md-12\">\n                                <p class=\"mbr-text mbr-fonts-style\" mbr-theme-style=\"display-4\">Module 1: Market Foundations (Beginner Level)<br><br>✅ Goal: Build strong basics &amp; understand how markets work.<br>✅ Introduction to financial markets (Stocks, Equity, MCX, F&amp;O)<br>✅ Order types &amp; trading platforms (Market, Limit, SL, Bracket, Cover)<br>✅ Equity basics: Delivery vs. Intraday trading<br>✅ Corporate actions (Dividends, Splits, Rights, Bonus)<br>✅ Candlestick basics, Support &amp; Resistance, Trendlines<br>✅ Simple indicators (Moving Averages, RSI, MACD)<br>✅ Basics of Fundamental Analysis (Financial statements, simple ratios)<br>✅ Risk management fundamentals (Stop-loss, position sizing, capital safety)</p>\n                            </div>\n                        </div>\n                    </div>\n                    <div id=\"tab2\" class=\"tab-pane\" role=\"tabpanel\" mbr-if=\"bootstrapTabs > 1\">\n                        <div class=\"row\">\n                            <div class=\"col-md-12\">\n                                <p class=\"mbr-text mbr-fonts-style\" mbr-theme-style=\"display-4\">&nbsp;Module 2: Trading &amp; Investing Strategies (Intermediate Level)<br><br>✅ Goal: Learn practical tools &amp; strategies for real-world trading.<br>✅ Advanced charting (patterns, breakouts, volume analysis)<br>✅ Futures trading (Lot size, margin, rollover, open interest)<br>✅ Options basics (Calls, Puts, Option chain, ITM/ATM/OTM)<br>✅ Beginner options strategies (Covered Call, Bull Call Spread, Protective Put)<br>✅ MCX basics (Gold, Silver, Crude Oil, Agri commodities)<br>✅ Equity investing strategies (Growth vs. Value, Sector analysis, Portfolio diversification)<br>✅ Swing &amp; positional trading setups<br>✅ Risk-reward ratios, trade journaling &amp; consistency building</p>\n                            </div>\n                        </div>\n                    </div>\n                    <div id=\"tab3\" class=\"tab-pane\" role=\"tabpanel\" mbr-if=\"bootstrapTabs > 2\">\n                        <div class=\"row\">\n                            <div class=\"col-md-12\">\n                                <p class=\"mbr-text mbr-fonts-style\" mbr-theme-style=\"display-4\">&nbsp;Module 3: Professional Mastery (Advanced Level)<br><br>✅ Goal: Trade like institutions &amp; manage multi-asset portfolios.<br>✅ Market Microstructure &amp; Order Flow insights<br>✅ Option Greeks (Delta, Gamma, Theta, Vega) with real use cases<br>✅ Implied Volatility (IV), Skew &amp; Volatility trading<br>✅ Advanced Option Strategies (Straddle, Strangle, Iron Condor, Butterfly, Ratio, Calendar spreads)<br>✅ Futures arbitrage &amp; spread trading (Index, Stock, Commodities)<br>✅ Advanced Commodity trading (Contango, Backwardation, Global correlations)<br>✅ Quantitative &amp; Algo basics (Backtesting, Rule-based strategies)<br>✅ Portfolio Management (MPT, CAPM, Hedging with derivatives)<br>✅ Pro-level risk management (Kelly Criterion, Drawdown control)<br>✅ Trading psychology &amp; behavioral finance<br>✅ Back market practice (Intraday scalping, swing trades, event-based strategies)</p>\n                            </div>\n                        </div>\n                    </div>\n                    <div id=\"tab4\" class=\"tab-pane\" role=\"tabpanel\" mbr-if=\"bootstrapTabs > 3\">\n                        <div class=\"row\">\n                            <div class=\"col-md-12\">\n                                <p class=\"mbr-text mbr-fonts-style\" mbr-theme-style=\"display-7\">Option chain analysis (NSE Option Chain, OI analysis)<br><br>Implied Volatility (IV) vs. Historical Volatility (HV)<br><br>Skew &amp; volatility smile<br><br>Greeks in practice (Delta-neutral hedging, Gamma scalping)<br><br>Calendar spreads, Diagonal spreads<br><br>Advanced multi-leg hedging strategies<br><br>Ratio spreads (Call Ratio, Put Ratio)<br><br>Synthetic positions (synthetic futures, synthetic calls/puts)<br><br>Iron Condor Adjustments, Broken Wing Butterfly<br><br>Advanced hedging with options (portfolio insurance)<br><br>Earnings season option strategies<br><br>Event-based trading (budget, Fed policy, RBI meetings)<br></p>\n                            </div>\n                        </div>\n                    </div>\n                    <div id=\"tab5\" class=\"tab-pane\" role=\"tabpanel\" mbr-if=\"bootstrapTabs > 4\">\n                        <div class=\"row\">\n                            <div class=\"col-md-12\">\n                                <p class=\"mbr-text mbr-fonts-style\" mbr-theme-style=\"display-7\">Global commodity correlations (Gold vs USD, Oil vs INR, Agri vs Monsoon)<br><br>Commitment of Traders (COT) report analysis<br><br>Seasonality patterns in commodities<br><br>Contango vs. Backwardation in commodity futures<br><br>Arbitrage between MCX &amp; international markets (COMEX, NYMEX)<br><br>Hedging physical business risk with MCX</p>\n                            </div>\n                        </div>\n                    </div>\n                    <div id=\"tab6\" class=\"tab-pane\" role=\"tabpanel\" mbr-if=\"bootstrapTabs > 5\">\n                        <div class=\"row\">\n                            <div class=\"col-md-12\">\n                                <p class=\"mbr-text mbr-fonts-style\" mbr-theme-style=\"display-7\">Introduction to algo trading &amp; APIs<br><br>Backtesting strategies with historical data<br><br>Mean reversion &amp; momentum strategies<br><br>Risk-adjusted returns (Sharpe, Sortino, Beta, Alpha)<br><br>Building rule-based systems (Python/Excel basics)<br><br>High-frequency trading insights</p>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_cid": "uXciN9euPu",
          "_anchor": "tabs1-ct",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "_name": "afeatures5",
          "_sourceTheme": "algom5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"features5 algom5\" group=\"Features\" data-bg-video=\"{{bg.type == 'video' && bg.value.url}}\" mbr-class=\"{'mbr-parallax-background': bg.parallax}\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\">\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"1\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"1\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showMainTitle\" checked>\n        <input type=\"checkbox\" title=\"Subtitle\" name=\"showMainSubtitle\" checked>\n        <input type=\"checkbox\" title=\"Buttons\" name=\"showButtons\" checked>\n        <header>Card</header>\n        <input type=\"checkbox\" title=\"Number\" name=\"showNumber\" checked>\n        <input type=\"color\" title=\"Number Color\" name=\"numberColor\" value=\"#FFFFFF\" condition=\"showNumber\">\n        <input type=\"color\" title=\"Number Bg Color\" name=\"numberBgColor\" value=\"#e6c63b\" condition=\"showNumber\">\n        <input type=\"checkbox\" title=\"Icon\" name=\"showIcon\" checked>\n        <input type=\"color\" title=\"Icon Color\" name=\"iconColor\" value=\"#112B6D\" condition=\"showIcon\">\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\">\n        <select title=\"Cards\" name=\"cardsAmount\">\n            <option value=\"1\">1</option>\n            <option value=\"2\">2</option>\n            <option value=\"3\" selected>3</option>\n        </select>\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"@ADDONS_PATH@/algom5/components/_images/background1.jpg\" parallax>\n            <input type=\"color\" title=\"Color\" value=\"#000000\" selected>\n            <input type=\"video\" title=\"Video\" value=\"https://vimeo.com/428046504\">\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"@ADDONS_PATH@/algom5/components/_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#FFF5EE\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.5\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type!== 'color'\" mbr-style=\"{'opacity': overlayOpacity, 'background-color': overlayColor}\">\n    </div>\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row\">\n            <div class=\"col-12 col-title\" mbr-if=\"showMainTitle || showMainSubtitle\">\n                <h3 class=\"mbr-section-title mbr-fonts-style align-center mb-0\" mbr-theme-style=\"display-2\" mbr-if=\"showMainTitle\" data-app-selector=\".mbr-section-title, .mbr-section-btn\"><b>We Simplify Trading</b><b><br></b></h3>\n                <h5 class=\"mbr-section-subtitle mbr-fonts-style align-center mb-0\" mbr-theme-style=\"display-4\" mbr-if=\"showMainSubtitle\" data-app-selector=\".mbr-section-subtitle\">At Finbytech Education, we’ve designed a learning journey that transforms absolute beginners into confident, consistent traders. With no prior market experience required, we equip you with the skills and strategies to accelerate your financial growth and take control of your future.\"</h5>\n            </div>\n        </div>\n        <div class=\"row\">\n            <div class=\"col-12 number-container\" mbr-if=\"showNumber\">\n                <div class=\"number-item\">\n                    <div class=\"number-text\">\n                        1\n                    </div>\n                </div>\n                <div class=\"number-item\" mbr-if=\"cardsAmount >1\">\n                    <div class=\"number-text\">\n                        2\n                    </div>\n                </div>\n                <div class=\"number-item\" mbr-if=\"cardsAmount >2\">\n                    <div class=\"number-text\">\n                        3\n                    </div>\n                </div>\n            </div>\n            <div class=\"col-12 cards-container\" mbr-if=\"showIcon || showText || showTitle\">\n                <div class=\"card\">\n                    <div class=\"card-box\">\n                        <div class=\"iconfont-wrapper\" mbr-if=\"showIcon\">\n                            <span mbr-icon class=\"mbr-iconfont mobi-mbri-contact-form mobi-mbri\" style=\"color: rgb(255, 255, 255); fill: rgb(255, 255, 255); font-size: 44px;\"></span>\n                        </div>\n                        <div class=\"card-container\" mbr-if=\"showText || showTitle\">\n                            <h5 class=\"card-title align-center mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"showTitle\" data-app-selector=\".card-title\"><b>Revision Classes</b></h5>\n                            <p class=\"card-text align-center mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"showText\" data-app-selector=\".card-text\">Part-time or full-time traders of Stock Market (NSE), Commodities Market (NCDEX) or Metals Exchange (MCX)&nbsp;<br></p>\n                        </div>\n                    </div>\n                </div>\n                <div class=\"card\" mbr-if=\"cardsAmount >1\">\n                    <div class=\"card-box\">\n                        <div class=\"iconfont-wrapper\" mbr-if=\"showIcon\">\n                            <span mbr-icon class=\"mbr-iconfont mobi-mbri-user mobi-mbri\" style=\"color: rgb(255, 255, 255); fill: rgb(255, 255, 255); font-size: 44px;\"></span>\n                        </div>\n                        <div class=\"card-container\" mbr-if=\"showText || showTitle\">\n                            <h5 class=\"card-title align-center mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"showTitle\" data-app-selector=\".card-title\"><b>Trading System Development</b></h5>\n                            <p class=\"card-text align-center mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"showText\" data-app-selector=\".card-text\">\n                                Dolor morbi non arcu risus quis varius quam.\n                                Auctor urna nunc id cursus metus\n                            </p>\n                        </div>\n                    </div>\n                </div>\n                <div class=\"card\" mbr-if=\"cardsAmount >2\">\n                    <div class=\"card-box\">\n                        <div class=\"iconfont-wrapper\" mbr-if=\"showIcon\">\n                            <span mbr-icon class=\"mbr-iconfont mobi-mbri-smile-face mobi-mbri\" style=\"color: rgb(255, 255, 255); fill: rgb(255, 255, 255); font-size: 44px;\"></span>\n                        </div>\n                        <div class=\"card-container\" mbr-if=\"showText || showTitle\">\n                            <h5 class=\"card-title align-center mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"showTitle\" data-app-selector=\".card-title\"><b>3 Months Support</b></h5>\n                            <p class=\"card-text align-center mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"showText\" data-app-selector=\".card-text\">\n                                Dolor morbi non arcu risus quis varius quam. Auctor urna nunc id cursus metus\n                            </p>\n                        </div>\n                    </div>\n                </div>\n            </div>\n            <div class=\"col-12 btn-container\" mbr-if=\"showButtons\">\n                <div mbr-buttons mbr-theme-style=\"display-4\" class=\"mbr-section-btn align-center\" mbr-if=\"showButtons\"><a class=\"btn btn-warning\" href=\"assets/files/Finbytechnovation_Final_Brochure_With_Logo.pdf\" data-app-placeholder=\"Type Text\" target=\"_blank\">\n                        <span class=\"mobi-mbri mobi-mbri-right mbr-iconfont mbr-iconfont-btn\"></span>\n                        Click here to explore course&nbsp;</a></div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_styles": {
            "padding-top": "(@paddingTop * 1rem)",
            "padding-bottom": "(@paddingBottom * 1rem)",
            "& when (@bg-type = \"color\")": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = \"image\")": {
              "background-image": "url(@bg-value)"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            ".col-title": {
              "margin-bottom": "30px",
              "padding": "0 30px !important"
            },
            ".mbr-section-title": {
              "color": "#112B6D"
            },
            ".mbr-section-subtitle": {
              "color": "#ffffff",
              "margin-top": "20px",
              "text-align": "center"
            },
            ".number-container": {
              "display": "flex",
              "justify-content": "center",
              "align-items": "center",
              "width": "100%",
              "padding": "20px 0",
              "@media (max-width: 767px)": {
                "display": "none"
              }
            },
            ".number-item": {
              "position": "relative",
              "display": "flex",
              "justify-content": "center",
              "align-items": "center",
              "width": "(100% / 3)",
              "padding": "0 10px",
              "&:not(:first-child)": {
                "&::after": {
                  "content": "\"\"",
                  "position": "absolute",
                  "width": "100%",
                  "height": "2px",
                  "right": "50%",
                  "top": "~\"calc(50% - 1px)\"",
                  "background-color": "@numberBgColor"
                }
              }
            },
            ".number-text": {
              "position": "relative",
              "z-index": "5",
              "display": "flex",
              "align-items": "center",
              "justify-content": "center",
              "width": "50px",
              "height": "50px",
              "border-radius": "50%",
              "font-size": "30px",
              "color": "@numberColor",
              "background-color": "@numberBgColor"
            },
            ".cards-container": {
              "display": "flex",
              "align-items": "stretch",
              "justify-content": "center",
              "margin-top": "40px",
              "@media (max-width: 767px)": {
                "flex-wrap": "wrap"
              }
            },
            ".card": {
              "width": "(100% / 3)",
              "padding": "10px",
              "@media (max-width: 767px)": {
                "width": "100%",
                "padding": "0 10px 30px"
              }
            },
            ".card-box": {
              "width": "100%",
              "@media (max-width: 767px)": {
                "display": "flex",
                "align-items": "center"
              }
            },
            ".iconfont-wrapper": {
              "display": "flex",
              "justify-content": "center",
              "width": "100%",
              "overflow": "hidden",
              "margin-bottom": "20px",
              "@media (max-width: 767px)": {
                "min-width": "130px",
                "width": "auto",
                "margin-bottom": "0",
                "margin-right": "25px"
              },
              ".mbr-iconfont": {
                "font-size": "130px",
                "color": "@iconColor",
                "@media (max-width: 767px)": {
                  "font-size": "80px"
                }
              }
            },
            ".card-container": {
              "width": "100%",
              "padding": "20px 20px 0",
              "@media (max-width: 767px)": {
                "flex-grow": "1",
                "padding": "0"
              }
            },
            ".card-title": {
              "color": "#ffffff",
              "margin-bottom": "40px",
              "@media (max-width: 767px)": {
                "margin-bottom": "20px",
                "text-align": "left !important"
              }
            },
            ".card-text": {
              "color": "#ffffff",
              "margin-bottom": "0",
              "@media (max-width: 767px)": {
                "text-align": "left !important"
              }
            },
            ".btn-container": {
              "padding": "40px 30px 0 !important"
            },
            ".mbr-section-title, .mbr-section-btn": {
              "color": "#ffffff",
              "text-align": "center"
            }
          },
